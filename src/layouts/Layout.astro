---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = 'Gentle-AI — Desarrollo de software guiado por especificaciones con claridad y control.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<!-- Material+Symbols+Outlined glyphs are bundled through existing static CSS pipeline -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<ClientRouter />
		<title>{title}</title>
	</head>
	<body class="bg-background font-sans text-on-background antialiased">
		<slot />
	</body>
</html>
