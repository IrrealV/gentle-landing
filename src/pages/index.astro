---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Hero from '../components/ui/Hero.astro';
import FeaturesGrid from '../components/ui/FeaturesGrid.astro';
import GetStarted from '../components/ui/GetStarted.astro';
import HowItWorks from '../components/ui/HowItWorks.astro';
import Stats from '../components/ui/Stats.astro';
import Footer from '../components/ui/Footer.astro';
---

<Layout title="GENTLE-AI | Spec-Driven Development">
	<Navbar currentPath="/" variant="marketing" />

	<main class="pt-24" id="top" data-page-animation="home">
		<Hero ctaSecondaryHref="/docs" />
		<FeaturesGrid />
		<GetStarted />
		<HowItWorks />
		<Stats />
	</main>

	<Footer />
</Layout>
