---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="How It Works | GENTLE-AI">
	<Navbar currentPath="/how-it-works" />

	<main class="flex-grow bg-[#11131b] pt-20">
		<header class="relative overflow-hidden border-b border-outline-variant bg-surface px-8 pb-16 pt-24">
			<div class="blueprint-grid absolute inset-0 opacity-20"></div>
			<div class="relative z-10 mx-auto max-w-7xl">
				<div class="mono mb-4 text-sm font-bold tracking-[0.3em] text-secondary">SYSTEM_ARCHITECTURE_V2.0</div>
				<h1 class="mb-8 text-6xl font-extrabold uppercase leading-none tracking-tighter text-on-surface md:text-8xl">
					Spec-Driven <br />Development
				</h1>
				<p class="max-w-2xl text-lg leading-relaxed text-on-surface-variant md:text-xl">
					Deterministic workflow that forces intent, requirements, and architecture before implementation.
				</p>
			</div>
		</header>

		<section class="border-b border-outline-variant bg-surface-container-lowest py-20">
			<div class="mx-auto max-w-7xl px-8">
				<div class="mb-12 flex items-center justify-between">
					<h2 class="text-3xl font-bold uppercase tracking-tight">The 7-Phase Pipeline</h2>
					<div class="mx-8 h-px flex-grow bg-outline-variant opacity-30"></div>
					<span class="mono text-xs uppercase text-on-surface-variant">Flow Schematic</span>
				</div>

				<div class="mb-12 grid grid-cols-1 gap-1 md:grid-cols-7">
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">01</div><span class="material-symbols-outlined mb-4 text-primary">lightbulb</span><h3 class="mb-2 text-sm font-bold uppercase">Proposal</h3><p class="text-xs leading-relaxed text-on-surface-variant">What &amp; Why. Capture intent and approach.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">02</div><span class="material-symbols-outlined mb-4 text-primary" style="font-variation-settings: 'FILL' 1;">description</span><h3 class="mb-2 text-sm font-bold uppercase">Spec</h3><p class="text-xs leading-relaxed text-on-surface-variant">Define requirement scenarios.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">03</div><span class="material-symbols-outlined mb-4 text-primary">architecture</span><h3 class="mb-2 text-sm font-bold uppercase">Design</h3><p class="text-xs leading-relaxed text-on-surface-variant">Architecture and interfaces.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">04</div><span class="material-symbols-outlined mb-4 text-primary">list_alt</span><h3 class="mb-2 text-sm font-bold uppercase">Tasks</h3><p class="text-xs leading-relaxed text-on-surface-variant">Discrete verifiable units.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">05</div><span class="material-symbols-outlined mb-4 text-primary" style="font-variation-settings: 'FILL' 1;">terminal</span><h3 class="mb-2 text-sm font-bold uppercase">Apply</h3><p class="text-xs leading-relaxed text-on-surface-variant">Implement against contracts.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">06</div><span class="material-symbols-outlined mb-4 text-primary">verified</span><h3 class="mb-2 text-sm font-bold uppercase">Verify</h3><p class="text-xs leading-relaxed text-on-surface-variant">Validate scenario compliance.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
					<article class="group relative overflow-hidden border border-outline-variant bg-surface p-6 transition-colors hover:border-primary"><div class="mono absolute right-0 top-0 p-2 text-[10px] text-outline opacity-40">07</div><span class="material-symbols-outlined mb-4 text-primary" style="font-variation-settings: 'FILL' 1;">inventory_2</span><h3 class="mb-2 text-sm font-bold uppercase">Archive</h3><p class="text-xs leading-relaxed text-on-surface-variant">Close and sync accepted deltas.</p><div class="mt-4 h-1 w-0 bg-primary transition-all duration-300 group-hover:w-full"></div></article>
				</div>

				<div class="overflow-x-auto border border-outline-variant">
					<table class="w-full border-collapse text-left">
						<thead>
							<tr class="border-b border-outline-variant bg-surface-container-high">
								<th class="p-4 mono text-xs uppercase tracking-widest text-primary">Phase</th>
								<th class="p-4 mono text-xs uppercase tracking-widest text-primary">Artifact</th>
								<th class="p-4 mono text-xs uppercase tracking-widest text-primary">Purpose</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-outline-variant/30 text-sm">
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Proposal</td><td class="p-4 mono text-secondary">proposal.md</td><td class="p-4 text-on-surface-variant">Capture intent and scope.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Spec</td><td class="p-4 mono text-secondary">spec.md</td><td class="p-4 text-on-surface-variant">Define acceptance scenarios.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Design</td><td class="p-4 mono text-secondary">design.md</td><td class="p-4 text-on-surface-variant">Establish architecture decisions.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Tasks</td><td class="p-4 mono text-secondary">tasks.md</td><td class="p-4 text-on-surface-variant">Break into verifiable items.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Apply</td><td class="p-4 mono text-secondary">Source code</td><td class="p-4 text-on-surface-variant">Implement according to contracts.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Verify</td><td class="p-4 mono text-secondary">Verification report</td><td class="p-4 text-on-surface-variant">Confirm implementation parity.</td></tr>
							<tr class="hover:bg-surface-container transition-colors"><td class="p-4 font-bold uppercase">Archive</td><td class="p-4 mono text-secondary">Closed change</td><td class="p-4 text-on-surface-variant">Sync final deltas and close.</td></tr>
						</tbody>
					</table>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
