---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';
import TerminalWindow from '../components/ui/TerminalWindow.astro';

const sections = [
	{ id: 'system-overview',     label: 'System Overview',        labelEs: 'Visión General' },
	{ id: 'installation',        label: 'Installation',           labelEs: 'Instalación' },
	{ id: 'sdd-protocol',        label: 'SDD Protocol',           labelEs: 'Protocolo SDD' },
	{ id: 'engram-memory',       label: 'Engram — Memory',        labelEs: 'Engram — Memoria' },
	{ id: 'mcp-servers',         label: 'MCP Servers',            labelEs: 'Servidores MCP' },
	{ id: 'gga-hook',            label: 'GGA — Guardian Angel',   labelEs: 'GGA — Ángel Guardián' },
	{ id: 'loadable-skills',     label: 'Loadable Skills',        labelEs: 'Skills Cargables' },
	{ id: 'cli-reference',       label: 'CLI Reference',          labelEs: 'Referencia CLI' },
];
---

<Layout title="Docs | GENTLE-AI">
	<Navbar currentPath="/docs" />

	<!-- Navigation Arrows (Root-level fixed position to escape CSS transform containment bug) -->
	<button
		id="docs-prev"
		class="fixed left-4 lg:left-[calc(16rem+2rem)] top-1/2 z-[100] -translate-y-1/2 flex h-12 w-12 items-center justify-center border border-outline-variant bg-surface-container-lowest/80 text-on-surface-variant transition-all duration-200 hover:border-primary hover:text-primary backdrop-blur-sm disabled:opacity-20 disabled:cursor-not-allowed"
		aria-label="Previous section"
	>
		<span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
	</button>
	<button
		id="docs-next"
		class="fixed right-4 lg:right-8 top-1/2 z-[100] -translate-y-1/2 flex h-12 w-12 items-center justify-center border border-outline-variant bg-surface-container-lowest/80 text-on-surface-variant transition-all duration-200 hover:border-primary hover:text-primary backdrop-blur-sm disabled:opacity-20 disabled:cursor-not-allowed"
		aria-label="Next section"
	>
		<span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
	</button>

	<div data-page-animation="docs" class="flex min-h-screen flex-col bg-background pt-20">
		<div class="flex flex-1 overflow-hidden" style="height: calc(100vh - 80px);">

			<!-- Sidebar -->
			<aside id="docs-sidebar" class="hidden w-64 flex-shrink-0 overflow-y-auto border-r border-outline-variant bg-surface-container-lowest lg:block">
				<div class="p-6">
					<div class="mb-6 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
						data-label-en="Documentation" data-label-es="Documentación">Documentation</div>
					<nav class="space-y-1">
						{sections.map((s, i) => (
							<button
								class="docs-nav-btn w-full text-left px-3 py-2.5 font-mono text-[11px] uppercase tracking-wider text-on-surface-variant transition-all duration-200 hover:text-primary hover:bg-surface-container-low border-l-2 border-transparent"
								data-section={s.id}
								data-label-en={s.label}
								data-label-es={s.labelEs}
								data-index={i}
							>{s.label}</button>
						))}
					</nav>

					<div class="mt-8 border-t border-outline-variant pt-6">
						<a
							href="/how-it-works"
							class="flex items-center gap-2 px-3 py-2.5 font-mono text-[11px] uppercase tracking-wider text-on-surface-variant transition-all duration-200 hover:text-primary border border-outline-variant hover:border-primary/50"
							data-label-en="Architecture Guide"
							data-label-es="Guía de Arquitectura"
						>
							<span class="material-symbols-outlined text-sm" aria-hidden="true">description</span>
							Architecture Guide
						</a>
					</div>
				</div>
			</aside>

			<!-- Main content area -->
			<div class="flex flex-1 flex-col overflow-hidden min-h-0">

				<!-- Content + nav arrows -->
				<div class="relative flex flex-1 overflow-hidden min-h-0">

					<!-- Arrows moved to root level above -->

					<!-- Section content -->
					<main id="docs-content" class="flex-1 overflow-hidden min-h-0"><div id="docs-scroll" class="h-full overflow-y-auto px-16 py-12 lg:px-24" style="position:relative;">

						<!-- Progress bar -->
						<div class="mb-8 flex items-center gap-3">
							<div id="docs-progress-bar" class="flex gap-1.5">
								{sections.map((_, i) => (
									<div class="docs-progress-dot h-1.5 w-6 bg-outline-variant transition-all duration-300" data-dot={i}></div>
								))}
							</div>
							<span id="docs-counter" class="font-mono text-[10px] text-on-surface-variant">1 / {sections.length}</span>
						</div>

						<!-- Section 1: System Overview -->
						<section id="sec-system-overview" class="docs-section active max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">01</div>
							<h1 class="mb-6 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-i18n-en="The Gentleman <span class='text-primary'>Ecosystem</span>"
								data-i18n-es="El Ecosistema <span class='text-primary'>Gentleman</span>">
								The Gentleman <span class="text-primary">Ecosystem</span>
							</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Gentle-AI is a single CLI that configures your entire AI development environment in one shot. It installs Engram for persistent memory, SDD skills for structured development, MCP servers for external integrations, and a GGA pre-commit hook for AI-powered code review."
								data-label-es="Gentle-AI es una CLI que configura todo tu entorno de desarrollo IA en un solo paso. Instala Engram para memoria persistente, skills SDD para desarrollo estructurado, servidores MCP para integraciones externas, y un hook GGA pre-commit para revisión de código con IA.">
								Gentle-AI is a single CLI that configures your entire AI development environment in one shot. It installs Engram for persistent memory, SDD skills for structured development, MCP servers for external integrations, and a GGA pre-commit hook for AI-powered code review.
							</p>
							<div class="grid grid-cols-2 gap-4 md:grid-cols-4">
								<div class="border border-outline-variant bg-surface-container-lowest p-4 text-center">
									<div class="mb-2 text-2xl font-bold text-primary">1</div>
									<div class="font-mono text-[10px] uppercase text-on-surface-variant"
										data-label-en="Command" data-label-es="Comando">Command</div>
								</div>
								<div class="border border-outline-variant bg-surface-container-lowest p-4 text-center">
									<div class="mb-2 text-2xl font-bold text-secondary">6+</div>
									<div class="font-mono text-[10px] uppercase text-on-surface-variant"
										data-label-en="Agents" data-label-es="Agentes">Agents</div>
								</div>
								<div class="border border-outline-variant bg-surface-container-lowest p-4 text-center">
									<div class="mb-2 text-2xl font-bold text-primary">30+</div>
									<div class="font-mono text-[10px] uppercase text-on-surface-variant">Skills</div>
								</div>
								<div class="border border-outline-variant bg-surface-container-lowest p-4 text-center">
									<div class="mb-2 text-2xl font-bold text-secondary">∞</div>
									<div class="font-mono text-[10px] uppercase text-on-surface-variant"
										data-label-en="Memory" data-label-es="Memoria">Memory</div>
								</div>
							</div>
						</section>

						<!-- Section 2: Installation -->
						<section id="sec-installation" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">02</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="Installation" data-label-es="Instalación">Installation</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Three ways to install. One result: a fully configured AI ecosystem in under 5 minutes. The interactive TUI guides you through every decision."
								data-label-es="Tres formas de instalar. Un resultado: un ecosistema IA completamente configurado en menos de 5 minutos. La TUI interactiva te guía en cada decisión.">
								Three ways to install. One result: a fully configured AI ecosystem in under 5 minutes. The interactive TUI guides you through every decision.
							</p>

							<TerminalWindow title="brew (recommended)" description="macOS / Linux" class="mb-4 border border-outline-variant">
								<pre class="code-block text-[12px] text-on-surface-variant">brew tap <span class="text-primary">Gentleman-Programming/tap</span>
brew install <span class="text-primary">gentle-ai</span>
<span class="text-secondary">gentle-ai</span> install</pre>
							</TerminalWindow>

							<TerminalWindow title="go run (source)" description="Any OS with Go 1.24+" class="mb-4 border border-outline-variant">
								<pre class="code-block text-[12px] text-on-surface-variant">mkdir <span class="text-primary">gentle-ai</span>
cd <span class="text-primary">gentle-ai</span>
go run ./cmd/gentle-ai <span class="text-secondary">install</span></pre>
							</TerminalWindow>

							<TerminalWindow title="winget (Windows)" description="Windows 10+" class="border border-outline-variant">
								<pre class="code-block text-[12px] text-on-surface-variant">winget install <span class="text-primary">GentlemanProgramming.gentle-ai</span>
<span class="text-secondary">gentle-ai</span> install</pre>
							</TerminalWindow>
						</section>

						<!-- Section 3: SDD Protocol -->
						<section id="sec-sdd-protocol" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">03</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="SDD Protocol" data-label-es="Protocolo SDD">SDD Protocol</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Spec-Driven Development forces intent, requirements, and architecture before a single line of code is written. Seven phases, each with a concrete artifact, prevent implementation drift and knowledge loss."
								data-label-es="El Desarrollo Guiado por Especificaciones fuerza la intención, los requisitos y la arquitectura antes de escribir una sola línea de código. Siete fases, cada una con un artefacto concreto, previenen la desviación en la implementación.">
								Spec-Driven Development forces intent, requirements, and architecture before a single line of code is written. Seven phases, each with a concrete artifact, prevent implementation drift and knowledge loss.
							</p>
							<div class="overflow-x-auto border border-outline-variant">
								<table class="w-full text-left text-sm">
									<thead>
										<tr class="border-b border-outline-variant bg-surface-container-low">
											<th class="px-5 py-3 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
												data-label-en="Phase" data-label-es="Fase">Phase</th>
											<th class="px-5 py-3 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant">Artifact</th>
											<th class="px-5 py-3 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
												data-label-en="Purpose" data-label-es="Propósito">Purpose</th>
										</tr>
									</thead>
									<tbody class="divide-y divide-outline-variant/50 font-mono text-[11px]">
										{[
											['Proposal', 'proposal.md', 'Capture intent and scope'],
											['Spec', 'spec.md', 'Define acceptance scenarios'],
											['Design', 'design.md', 'Establish architecture'],
											['Tasks', 'tasks.md', 'Break into verifiable items'],
											['Apply', 'Source code', 'Implement contracts'],
											['Verify', 'verify-report.md', 'Confirm parity'],
											['Archive', 'Closed change', 'Sync and close'],
										].map(([phase, art, purpose]) => (
											<tr class="hover:bg-surface-container-low transition-colors">
												<td class="px-5 py-3 font-bold text-primary">{phase}</td>
												<td class="px-5 py-3 text-secondary">{art}</td>
												<td class="px-5 py-3 text-on-surface-variant">{purpose}</td>
											</tr>
										))}
									</tbody>
								</table>
							</div>
							
							<div class="mt-8 mb-4 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
								data-label-en="SDD Phases" data-label-es="Fases SDD">SDD Phases</div>
							<div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4">
								{['sdd-init', 'sdd-explore', 'sdd-propose', 'sdd-spec', 'sdd-design', 'sdd-tasks', 'sdd-apply', 'sdd-verify', 'sdd-archive', 'sdd-onboard', 'sdd-orchestrator'].map(skill => (
									<div class="border border-outline-variant bg-surface-container-low px-3 py-2 font-mono text-[10px] uppercase text-on-surface-variant hover:border-primary hover:text-primary transition-colors">{skill}</div>
								))}
							</div>
						</section>

						<!-- Section 4: Engram Memory -->
						<section id="sec-engram-memory" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">04</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="Engram — Persistent Memory"
								data-label-es="Engram — Memoria Persistente">Engram — Persistent Memory</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Engram is a local SQLite-backed memory system that survives context windows, compactions, and new sessions. Your AI agent remembers architectural decisions, bug fixes, and conventions across every conversation."
								data-label-es="Engram es un sistema de memoria local respaldado por SQLite que sobrevive ventanas de contexto, compactaciones y nuevas sesiones. Tu agente IA recuerda decisiones arquitectónicas, corrección de bugs y convenciones a través de cada conversación.">
								Engram is a local SQLite-backed memory system that survives context windows, compactions, and new sessions. Your AI agent remembers architectural decisions, bug fixes, and conventions across every conversation.
							</p>
							<TerminalWindow title="engram_schema.sql" description="Schema reference" class="border border-outline-variant">
								<pre class="code-block overflow-x-auto text-[11px] text-on-surface-variant"><span class="text-secondary">CREATE TABLE</span> observations (
  id <span class="text-primary">INTEGER PRIMARY KEY</span>,
  type <span class="text-secondary">TEXT</span>,         -- bugfix | decision | pattern | discovery
  title <span class="text-secondary">TEXT</span>,        -- short, searchable
  content <span class="text-secondary">TEXT</span>,      -- What / Why / Where / Learned
  project <span class="text-secondary">TEXT</span>,      -- scoped to your repo
  topic_key <span class="text-secondary">TEXT</span>,    -- upsert key for evolving topics
  created_at <span class="text-secondary">DATETIME</span>
);

<span class="text-secondary">CREATE VIRTUAL TABLE</span> obs_fts
<span class="text-secondary">USING</span> fts5(content, tokenize=<span class="text-secondary">'porter'</span>);</pre>
							</TerminalWindow>
						</section>

						<!-- Section 5: MCP Servers -->
						<section id="sec-mcp-servers" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">05</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="MCP Servers" data-label-es="Servidores MCP">MCP Servers</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Model Context Protocol connects your agent to real-world data and tools through stable, version-safe API contracts. No prompt engineering — just plug and play integration with any external service."
								data-label-es="Model Context Protocol conecta tu agente con datos y herramientas del mundo real a través de contratos de API estables y seguros en versiones. Sin prompt engineering — integración plug and play con cualquier servicio externo.">
								Model Context Protocol connects your agent to real-world data and tools through stable, version-safe API contracts. No prompt engineering — just plug and play integration with any external service.
							</p>
							<div class="space-y-3">
								{[
									{ name: 'Docs MCP', desc: 'Serve versioned internal documentation with deterministic retrieval', icon: 'book' },
									{ name: 'Engram MCP', desc: 'Expose persistent memory to any MCP-compatible agent', icon: 'memory' },
									{ name: 'Planning MCP', desc: 'Read and write project planning artifacts directly', icon: 'article' },
									{ name: 'Workflow MCP', desc: 'Track tasks, reviews, and delivery flow internally', icon: 'code' },
									{ name: 'Custom MCPs', desc: 'Any REST API can be wrapped with the MCP spec', icon: 'extension' },
								].map(item => (
									<div class="flex items-start gap-4 border border-outline-variant bg-surface-container-lowest p-4">
										<span class="material-symbols-outlined text-primary mt-0.5" aria-hidden="true">{item.icon}</span>
										<div>
											<div class="mb-1 font-mono text-xs font-bold uppercase text-on-surface">{item.name}</div>
											<div class="text-xs text-on-surface-variant">{item.desc}</div>
										</div>
									</div>
								))}
							</div>
						</section>

						<!-- Section 6: GGA Hook -->
						<section id="sec-gga-hook" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">06</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="GGA — Guardian Angel"
								data-label-es="GGA — Ángel Guardián">GGA — Guardian Angel</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="A zero-dependency Bash CLI that runs AI-powered code review on every git commit. GGA validates your staged files against team standards defined in AGENTS.md — before the code ever reaches the remote."
								data-label-es="Una CLI Bash sin dependencias que ejecuta revisión de código con IA en cada git commit. GGA valida tus archivos staged contra los estándares del equipo definidos en AGENTS.md — antes de que el código llegue al remoto.">
								A zero-dependency Bash CLI that runs AI-powered code review on every git commit. GGA validates your staged files against team standards defined in AGENTS.md — before the code ever reaches the remote.
							</p>
							<TerminalWindow title=".git/hooks/pre-commit" description="Auto-installed by gentle-ai" class="mb-6 border border-outline-variant">
								<pre class="code-block text-[12px] text-on-surface-variant"><span class="text-secondary">#!/usr/bin/env bash</span>
<span class="text-primary">gga</span> review --staged \
  --provider <span class="text-secondary">gentle-ai-core</span> \
  --rules <span class="text-secondary">AGENTS.md</span></pre>
							</TerminalWindow>
							<div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
								{['Gentle-AI Core', 'Gentle-AI Fast', 'Local Runtime', 'Team Runtime', 'Private Runtime', 'Offline Runtime'].map(p => (
									<div class="border border-outline-variant bg-surface-container-lowest px-3 py-2 font-mono text-[11px] text-on-surface-variant">{p}</div>
								))}
							</div>
						</section>

						<!-- Section 7: Loadable Skills -->
						<section id="sec-loadable-skills" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">07</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="Loadable Skills" data-label-es="Skills Cargables">Loadable Skills</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="Expert knowledge modules injected directly into agent context. Skills are auto-detected from your project and contain curated guidelines, patterns, and anti-patterns for each technology."
								data-label-es="Módulos de conocimiento experto inyectados directamente en el contexto del agente. Las skills son auto-detectadas de tu proyecto y contienen guías curadas, patrones y anti-patrones para cada tecnología.">
								Expert knowledge modules injected directly into agent context. Skills are auto-detected from your project and contain curated guidelines, patterns, and anti-patterns for each technology.
							</p>
							
							<div class="mb-4 font-mono text-[10px] uppercase tracking-widest text-secondary"
								data-label-en="Framework Skills" data-label-es="Skills de Frameworks">Framework Skills</div>
							<div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-4">
								{['React 19', 'Next.js 15', 'TypeScript', 'Tailwind 4', 'Zod 4', 'Playwright', 'Go testing', 'Vercel AI SDK', 'Drizzle ORM', 'tRPC', 'Prisma', 'Supabase', 'shadcn/ui', 'Bubbletea', 'Templ', 'branch-pr', 'issue-creation', 'judgment-day', 'skill-creator', 'skill-registry'].map(skill => (
									<div class="border border-outline-variant bg-surface-container-lowest px-3 py-2 font-mono text-[10px] uppercase text-on-surface-variant hover:border-primary hover:text-primary transition-colors">{skill}</div>
								))}
							</div>

							<p class="mt-4 font-mono text-[10px] text-on-surface-variant"
								data-label-en="+ more being added continuously. Contributions welcome."
								data-label-es="+ más se añaden continuamente. Se aceptan contribuciones.">
								+ more being added continuously. Contributions welcome.
							</p>
						</section>

						<!-- Section 8: CLI Reference -->
						<section id="sec-cli-reference" class="docs-section max-w-3xl">
							<div class="mb-2 font-mono text-xs uppercase tracking-widest text-secondary">08</div>
							<h1 class="mb-4 text-5xl font-extrabold uppercase leading-none tracking-tighter text-on-surface"
								data-label-en="CLI Reference" data-label-es="Referencia CLI">CLI Reference</h1>
							<p class="mb-8 text-lg leading-relaxed text-on-surface-variant"
								data-label-en="All commands available in the gentle-ai CLI. The interactive TUI covers the most common workflows; flags are for CI/CD pipelines and automation."
								data-label-es="Todos los comandos disponibles en la CLI de gentle-ai. La TUI interactiva cubre los flujos de trabajo más comunes; los flags son para pipelines de CI/CD y automatización.">
								All commands available in the gentle-ai CLI. The interactive TUI covers the most common workflows; flags are for CI/CD pipelines and automation.
							</p>
							<div class="space-y-2">
								{[
									{ cmd: 'gentle-ai install', desc: 'Full ecosystem setup — launches interactive TUI', descEs: 'Configuración completa — lanza TUI interactiva' },
									{ cmd: 'gentle-ai sync', desc: 'Sync all configs to latest ecosystem version', descEs: 'Sincroniza todas las configs a la última versión' },
									{ cmd: 'gentle-ai upgrade', desc: 'Upgrade tool versions non-destructively', descEs: 'Actualiza versiones de herramientas sin destruir' },
									{ cmd: 'gentle-ai version', desc: 'Print current version', descEs: 'Muestra la versión actual' },
									{ cmd: '--preset full-gentleman', desc: 'Install full Gentleman preset (non-interactive)', descEs: 'Instala el preset Gentleman completo (no interactivo)' },
									{ cmd: '--agent core', desc: 'Target specific capability tier', descEs: 'Apunta a una capacidad específica' },
									{ cmd: '--persona gentleman', desc: 'Apply persona configuration', descEs: 'Aplica configuración de persona' },
									{ cmd: '--dry-run', desc: 'Preview changes without applying', descEs: 'Previsualiza cambios sin aplicar' },
								].map(item => (
									<div class="border border-outline-variant bg-surface-container-lowest p-4">
										<code class="font-mono text-xs text-primary">{item.cmd}</code>
										<p class="mt-1 text-xs text-on-surface-variant"
											data-label-en={item.desc}
											data-label-es={item.descEs}>{item.desc}</p>
									</div>
								))}
							</div>
						</section>

					</div></main>
				</div>

				<!-- Bottom breadcrumb / section label -->
				<div class="border-t border-outline-variant bg-background px-6 py-3 flex items-center justify-between">
					<span id="docs-section-label" class="font-mono text-[10px] uppercase tracking-widest text-on-surface-variant">System Overview</span>
					<a
						href="/features"
						class="flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-colors"
						data-label-en="Feature Map"
						data-label-es="Mapa de Funciones"
					>
						<span class="material-symbols-outlined text-sm" aria-hidden="true">route</span>
						Feature Map
					</a>
				</div>
			</div>
		</div>

		<Footer />
	</div>
</Layout>

<script is:inline>
(function() {
	var sections = [
		'system-overview', 'installation', 'sdd-protocol',
		'engram-memory', 'mcp-servers', 'gga-hook',
		'loadable-skills', 'cli-reference'
	];
	var current = 0;
	var listenerController = null;

	var animating = false;

	function updateChrome(idx) {
		// Nav sidebar highlight
		var newBtn = document.querySelector('.docs-nav-btn[data-index="' + idx + '"]');
		document.querySelectorAll('.docs-nav-btn').forEach(function(b) {
			b.classList.remove('border-primary', 'text-primary');
		});
		if (newBtn) {
			newBtn.classList.add('border-primary', 'text-primary');
		}

		// Progress dots
		var dots = document.querySelectorAll('.docs-progress-dot');
		dots.forEach(function(d, i) {
			d.classList.toggle('bg-primary', i <= idx);
			d.classList.toggle('bg-outline-variant', i > idx);
			d.style.width = i === idx ? '28px' : '6px';
		});

		// Counter
		var counter = document.getElementById('docs-counter');
		if (counter) counter.textContent = (idx + 1) + ' / ' + sections.length;

		// Section label bottom bar
		var label = document.getElementById('docs-section-label');
		if (label && newBtn) label.textContent = newBtn.textContent.trim();

		// Arrow state
		var prev = document.getElementById('docs-prev');
		var next = document.getElementById('docs-next');
		if (prev) prev.disabled = idx === 0;
		if (next) next.disabled = idx === sections.length - 1;
	}

	function goTo(idx, forceDir) {
		if (idx < 0 || idx >= sections.length) return;
		if (idx === current || animating) return;

		var dir = forceDir || (idx > current ? 'next' : 'prev');
		var dirClass = dir === 'next' ? 'dir-next' : 'dir-prev';

		var oldEl = document.getElementById('sec-' + sections[current]);
		var newEl = document.getElementById('sec-' + sections[idx]);
		if (!oldEl || !newEl) return;

		animating = true;

		// Hide old immediately — the new one slides in over the blank
		oldEl.classList.remove('active', 'dir-next', 'dir-prev');

		current = idx;
		updateChrome(current);

		// Show new with slide
		newEl.classList.remove('dir-next', 'dir-prev');
		newEl.classList.add('active', dirClass);

		// Scroll wrapper to top
		var scroll = document.getElementById('docs-scroll');
		if (scroll) scroll.scrollTop = 0;

		// Release lock after animation
		setTimeout(function() {
			newEl.classList.remove(dirClass);
			animating = false;
		}, 380);
	}

	function cleanupListeners() {
		if (listenerController) {
			listenerController.abort();
			listenerController = null;
		}
	}

	function init() {
		cleanupListeners();
		listenerController = new AbortController();
		var signal = listenerController.signal;

		animating = false;
		current = 0;

		// Remove any stale active states
		document.querySelectorAll('.docs-section').forEach(function(s) {
			s.classList.remove('active', 'dir-next', 'dir-prev');
		});

		// Nav buttons
		var navBtns = document.querySelectorAll('.docs-nav-btn');
		navBtns.forEach(function(btn) {
			btn.addEventListener('click', function() {
				var idx = parseInt(btn.getAttribute('data-index') || '', 10);
				if (idx !== current) goTo(idx);
			}, { signal: signal });
		});

		// Arrows
		var prev = document.getElementById('docs-prev');
		var next = document.getElementById('docs-next');
		if (prev) prev.addEventListener('click', function() { goTo(current - 1, 'prev'); }, { signal: signal });
		if (next) next.addEventListener('click', function() { goTo(current + 1, 'next'); }, { signal: signal });

		// Keyboard
		document.addEventListener('keydown', function(e) {
			if (e.key === 'ArrowRight' || e.key === 'ArrowDown') goTo(current + 1, 'next');
			if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   goTo(current - 1, 'prev');
		}, { signal: signal });

		// Show first section directly (no animation on initial load)
		var firstEl = document.getElementById('sec-' + sections[0]);
		if (firstEl) firstEl.classList.add('active');
		updateChrome(0);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init, { once: true });
	} else {
		init();
	}
	document.addEventListener('astro:page-load', init);
	document.addEventListener('astro:before-swap', cleanupListeners);
	document.addEventListener('astro:page-unload', cleanupListeners);
})();
</script>
