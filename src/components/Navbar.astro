---
interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const links = [
	{ href: '/features', label: 'Features' },
	{ href: '/how-it-works', label: 'How It Works' },
	{ href: '/docs', label: 'Documentation' },
	{ href: '/configurator', label: 'Configurator' },
];
---

<header data-home-section="navbar" class="fixed top-0 z-50 w-full border-b border-[#1a1f2e] bg-[#06080f]">
	<nav class="flex w-full max-w-full items-center justify-between px-8 py-4">
		<a href="/" class="flex items-center gap-2" aria-label="Go to home">
			<span class="flex h-6 w-6 items-center justify-center border border-[#1a1f2e] bg-surface-container-low text-[#7FB4CA]" aria-hidden="true">
				<span class="material-symbols-outlined text-sm">terminal</span>
			</span>
			<span class="font-['Space_Grotesk'] text-xl font-bold uppercase tracking-tighter text-[#7FB4CA]">GENTLE-AI</span>
		</a>

		<div class="hidden items-center space-x-8 md:flex">
			{
				links.map((link) => {
					const isActive = currentPath === link.href;

					return (
						<a
							href={link.href}
							class:list={[
								'transition-colors duration-200',
								isActive
									? "border-b-2 border-[#7FB4CA] pb-1 font-['Space_Grotesk'] tracking-tight text-[#7FB4CA]"
									: 'font-mono text-xs uppercase tracking-widest text-[#8892A0] hover:text-[#E0C15A]',
							]}
						>
							{link.label}
						</a>
					);
				})
			}
		</div>

		<div class="flex items-center gap-3">
			<div class="flex cursor-default items-center gap-1 border border-outline-variant bg-surface-container-high px-2 py-1 text-[#8892A0] transition-colors duration-200 hover:text-[#E0C15A]">
				<span class="material-symbols-outlined text-sm">language</span>
				<span class="font-mono text-xs">EN</span>
			</div>
			<div class="hidden items-center gap-2 border border-[#1a1f2e] bg-surface-container-low px-3 py-1 md:flex">
				<span class="h-2 w-2 bg-[#7FB4CA]"></span>
				<span class="font-mono text-[10px] uppercase tracking-widest text-[#8892A0]">System Status: Operational</span>
			</div>
		</div>

		<details class="relative md:hidden">
			<summary class="list-none cursor-pointer text-[#8892A0]" aria-label="Toggle navigation menu">
				<span class="material-symbols-outlined">menu</span>
			</summary>
			<div id="mobile-nav-menu" class="absolute right-0 top-full mt-4 w-64 border border-outline-variant bg-surface-container-low">
				<div class="flex flex-col px-4 py-3">
					{
						links.map((link) => {
							const isActive = currentPath === link.href;

							return (
								<a
									href={link.href}
									class:list={[
										'border-b border-outline-variant/40 py-3 font-mono text-xs uppercase tracking-widest transition-colors last:border-b-0',
										isActive ? 'text-primary' : 'text-on-surface-variant hover:text-secondary',
									]}
								>
									{link.label}
								</a>
							);
						})
					}
				</div>
			</div>
		</details>
	</nav>

	<a href="#" class="sr-only">Skip to top</a>

</header>
