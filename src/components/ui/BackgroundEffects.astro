---
// BackgroundEffects.astro
// Canvas dot-grid mesh background.
---

<canvas
	id="bg-canvas"
	style="position: fixed; inset: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none;"
	aria-hidden="true"
></canvas>

<script is:inline>
	(function () {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		var COLS = 26;
		var ROWS = 16;
		var state =
			window.__glBgCanvasState ||
			(window.__glBgCanvasState = {
				dots: [],
				mouseX: -9999,
				mouseY: -9999,
				drawLoopRunning: false,
				lastT: 0,
			});

		function buildGrid(canvas) {
			state.dots = [];
			for (var r = 0; r < ROWS; r++) {
				for (var c = 0; c < COLS; c++) {
					state.dots.push({
						col: c,
						row: r,
						baseX: (c / (COLS - 1)) * canvas.width,
						baseY: (r / (ROWS - 1)) * canvas.height,
						x: 0,
						y: 0,
						phase: Math.random() * Math.PI * 2,
						speed: 0.35 + Math.random() * 0.45,
					});
				}
			}
		}

		function getDot(c, r) {
			if (c < 0 || c >= COLS || r < 0 || r >= ROWS) return null;
			return state.dots[r * COLS + c];
		}

		function draw(t) {
			var canvas = document.getElementById('bg-canvas');
			var ctx = canvas ? canvas.getContext('2d') : null;
			if (!canvas || !ctx) {
				state.drawLoopRunning = false;
				return;
			}

			requestAnimationFrame(draw);
			if (t - state.lastT < 16) return;
			state.lastT = t;

			ctx.clearRect(0, 0, canvas.width, canvas.height);

			var REPEL_R = 180;
			for (var i = 0; i < state.dots.length; i++) {
				var d = state.dots[i];
				var dx = d.baseX - state.mouseX;
				var dy = d.baseY - state.mouseY;
				var dist2 = dx * dx + dy * dy;
				var ox = 0;
				var oy = 0;
				if (dist2 < REPEL_R * REPEL_R) {
					var dist = Math.sqrt(dist2);
					if (dist > 0.0001) {
						var force = (1 - dist / REPEL_R) * 34;
						ox = (dx / dist) * force;
						oy = (dy / dist) * force;
					}
				}
				var breath = Math.sin(t * 0.0004 * d.speed + d.phase) * 2.2;
				d.x = d.baseX + ox;
				d.y = d.baseY + oy + breath;
			}

			for (var rr = 0; rr < ROWS; rr++) {
				for (var cc = 0; cc < COLS; cc++) {
					var a = getDot(cc, rr);
					var nb = getDot(cc + 1, rr);
					var nd = getDot(cc, rr + 1);

					if (nb) {
						var edx = a.x - nb.x;
						var edy = a.y - nb.y;
						var elen = Math.sqrt(edx * edx + edy * edy);
						var eBase = canvas.width / (COLS - 1);
						var stretch = Math.abs(elen - eBase) / eBase;
						var alpha = Math.max(0, 0.3 - stretch * 0.35) * 0.4;
						ctx.beginPath();
						ctx.moveTo(a.x, a.y);
						ctx.lineTo(nb.x, nb.y);
						ctx.strokeStyle = 'rgba(127,180,202,' + alpha + ')';
						ctx.lineWidth = 0.9;
						ctx.stroke();
					}
					if (nd) {
						var edx2 = a.x - nd.x;
						var edy2 = a.y - nd.y;
						var elen2 = Math.sqrt(edx2 * edx2 + edy2 * edy2);
						var eBase2 = canvas.height / (ROWS - 1);
						var stretch2 = Math.abs(elen2 - eBase2) / eBase2;
						var alpha2 = Math.max(0, 0.3 - stretch2 * 0.35) * 0.4;
						ctx.beginPath();
						ctx.moveTo(a.x, a.y);
						ctx.lineTo(nd.x, nd.y);
						ctx.strokeStyle = 'rgba(127,180,202,' + alpha2 + ')';
						ctx.lineWidth = 0.9;
						ctx.stroke();
					}
				}
			}

			for (var j = 0; j < state.dots.length; j++) {
				var d2 = state.dots[j];
				var ddx = d2.x - state.mouseX;
				var ddy = d2.y - state.mouseY;
				var dDist = Math.sqrt(ddx * ddx + ddy * ddy);
				var prox = Math.max(0, 1 - dDist / 200);
				var dotAlpha = Math.min((0.55 + prox * 0.4) * 0.4, 1);
				var radius = 2.6 + prox * 2.4;
				ctx.beginPath();
				ctx.arc(d2.x, d2.y, radius, 0, Math.PI * 2);
				ctx.fillStyle = prox > 0.3 ? 'rgba(224,193,90,' + dotAlpha + ')' : 'rgba(127,180,202,' + dotAlpha + ')';
				ctx.fill();
			}
		}

		function resize() {
			var canvas = document.getElementById('bg-canvas');
			if (!canvas) return;
			canvas.width = window.innerWidth;
			canvas.height = window.innerHeight;
			buildGrid(canvas);
		}

		function init() {
			resize();
			if (!state.drawLoopRunning) {
				state.drawLoopRunning = true;
				requestAnimationFrame(draw);
			}
		}

		if (!window.__glBgCanvasEventsBound) {
			document.addEventListener('mousemove', function (e) {
				state.mouseX = e.clientX;
				state.mouseY = e.clientY;
			});
			document.addEventListener('mouseleave', function () {
				state.mouseX = -9999;
				state.mouseY = -9999;
			});
			window.addEventListener('resize', resize);
			document.addEventListener('astro:page-load', function () {
				state.mouseX = -9999;
				state.mouseY = -9999;
				resize();
				if (!state.drawLoopRunning) {
					state.drawLoopRunning = true;
					requestAnimationFrame(draw);
				}
			});
			window.__glBgCanvasEventsBound = true;
		}

		init();
	})();
</script>
