---
// BackgroundEffects.astro
// Canvas dot-grid mesh — z-index:1 con pointer-events:none para que quede
// encima del background del body pero debajo del contenido de la página.
// Sin cursor glow.
---

<canvas
	id="bg-canvas"
	style="position: fixed; inset: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none;"
	aria-hidden="true"
></canvas>

<script is:inline>
(function () {
	if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

	var COLS = 26;
	var ROWS = 16;
	var dots = [];
	var mouseX = -9999;
	var mouseY = -9999;
	var drawLoopRunning = false;

	function buildGrid(canvas) {
		dots = [];
		for (var r = 0; r < ROWS; r++) {
			for (var c = 0; c < COLS; c++) {
				dots.push({
					col: c, row: r,
					baseX: (c / (COLS - 1)) * canvas.width,
					baseY: (r / (ROWS - 1)) * canvas.height,
					x: 0, y: 0,
					phase: Math.random() * Math.PI * 2,
					speed: 0.35 + Math.random() * 0.45,
				});
			}
		}
	}

	function getDot(c, r) {
		if (c < 0 || c >= COLS || r < 0 || r >= ROWS) return null;
		return dots[r * COLS + c];
	}

	var lastT = 0;
	function draw(t) {
		var canvas = document.getElementById('bg-canvas');
		var ctx = canvas ? canvas.getContext('2d') : null;
		if (!canvas || !ctx) { drawLoopRunning = false; return; }

		requestAnimationFrame(draw);
		if (t - lastT < 16) return;
		lastT = t;

		/* Limpia con el color de fondo — canvas IS el fondo */
		ctx.clearRect(0, 0, canvas.width, canvas.height);

		/* Actualiza posiciones */
		var REPEL_R = 180;
		for (var i = 0; i < dots.length; i++) {
			var d = dots[i];
			var dx = d.baseX - mouseX;
			var dy = d.baseY - mouseY;
			var dist2 = dx * dx + dy * dy;
			var ox = 0, oy = 0;
			if (dist2 < REPEL_R * REPEL_R) {
				var dist = Math.sqrt(dist2);
				var force = (1 - dist / REPEL_R) * 34;
				ox = (dx / dist) * force;
				oy = (dy / dist) * force;
			}
			var breath = Math.sin(t * 0.0004 * d.speed + d.phase) * 2.2;
			d.x = d.baseX + ox;
			d.y = d.baseY + oy + breath;
		}

		/* Líneas */
		for (var r = 0; r < ROWS; r++) {
			for (var c = 0; c < COLS; c++) {
				var a = getDot(c, r);
				var nb = getDot(c + 1, r);
				var nd = getDot(c, r + 1);

				if (nb) {
					var edx = a.x - nb.x;
					var edy = a.y - nb.y;
					var elen = Math.sqrt(edx * edx + edy * edy);
					var eBase = canvas.width / (COLS - 1);
					var stretch = Math.abs(elen - eBase) / eBase;
					var alpha = Math.max(0, 0.30 - stretch * 0.35) * 0.4;
					ctx.beginPath();
					ctx.moveTo(a.x, a.y);
					ctx.lineTo(nb.x, nb.y);
					ctx.strokeStyle = 'rgba(127,180,202,' + alpha + ')';
					ctx.lineWidth = 0.9;
					ctx.stroke();
				}
				if (nd) {
					var edx2 = a.x - nd.x;
					var edy2 = a.y - nd.y;
					var elen2 = Math.sqrt(edx2 * edx2 + edy2 * edy2);
					var eBase2 = canvas.height / (ROWS - 1);
					var stretch2 = Math.abs(elen2 - eBase2) / eBase2;
					var alpha2 = Math.max(0, 0.30 - stretch2 * 0.35) * 0.4;
					ctx.beginPath();
					ctx.moveTo(a.x, a.y);
					ctx.lineTo(nd.x, nd.y);
					ctx.strokeStyle = 'rgba(127,180,202,' + alpha2 + ')';
					ctx.lineWidth = 0.9;
					ctx.stroke();
				}
			}
		}

		/* Puntos */
		for (var j = 0; j < dots.length; j++) {
			var d2 = dots[j];
			var ddx = d2.x - mouseX;
			var ddy = d2.y - mouseY;
			var dDist = Math.sqrt(ddx * ddx + ddy * ddy);
			var prox = Math.max(0, 1 - dDist / 200);
			var dotAlpha = Math.min((0.55 + prox * 0.40) * 0.4, 1);
			var radius = 2.6 + prox * 2.4;
			ctx.beginPath();
			ctx.arc(d2.x, d2.y, radius, 0, Math.PI * 2);
			ctx.fillStyle = prox > 0.3
				? 'rgba(224,193,90,' + dotAlpha + ')'
				: 'rgba(127,180,202,' + dotAlpha + ')';
			ctx.fill();
		}
	}

	function resize() {
		var canvas = document.getElementById('bg-canvas');
		if (!canvas) return;
		canvas.width = window.innerWidth;
		canvas.height = window.innerHeight;
		buildGrid(canvas);
	}

	function init() {
		resize();
		if (!drawLoopRunning) {
			drawLoopRunning = true;
			requestAnimationFrame(draw);
		}
	}

	/* Mouse — registrado una sola vez, mouseX/Y son globales del closure */
	document.addEventListener('mousemove', function (e) {
		mouseX = e.clientX;
		mouseY = e.clientY;
	});
	document.addEventListener('mouseleave', function () {
		mouseX = -9999;
		mouseY = -9999;
	});

	window.addEventListener('resize', resize);

	init();

	/* Re-calibra grid en cada navegación (View Transitions) */
	document.addEventListener('astro:page-load', function () {
		mouseX = -9999;
		mouseY = -9999;
		resize();
	});
})();
</script>
