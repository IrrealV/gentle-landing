---
import CopyButton from './CopyButton.astro';

interface Props {
	ctaSecondaryHref: `/${string}` | `#${string}`;
}

const { ctaSecondaryHref } = Astro.props;
const OFFICIAL_REPO_URL = 'https://github.com/Gentleman-Programming/gentle-ai';
---


<section data-home-section="hero" class="mx-auto grid max-w-[1200px] grid-cols-1 items-center gap-12 px-6 pb-24 pt-12 lg:grid-cols-12 lg:items-start lg:gap-10">
	<!-- Left column -->
	<div class="will-animate lg:col-span-5 lg:col-start-1" data-animate="slide-left">
		<h1 class="mono mb-4 text-4xl font-extrabold leading-[1.1] tracking-tighter text-on-surface md:text-6xl">
			<span
				data-i18n-en="<span class='text-primary whitespace-nowrap'>CONFIGURE</span> <span class='text-secondary whitespace-nowrap'>YOUR AI CODING</span> <span class='text-tertiary whitespace-nowrap'>ECOSYSTEM.</span>"
				data-i18n-es="<span class='text-primary whitespace-nowrap'>CONFIGURA</span> <span class='text-secondary whitespace-nowrap'>TU ECOSISTEMA</span> <span class='text-tertiary whitespace-nowrap'>DE CODING CON IA.</span>"
			><span class="text-primary whitespace-nowrap">CONFIGURE</span> <span class="text-secondary whitespace-nowrap">YOUR AI CODING</span> <span class="text-tertiary whitespace-nowrap">ECOSYSTEM.</span></span>
		</h1>

		<p class="mb-4 max-w-xl text-base leading-relaxed text-on-surface-variant"
			data-label-en="gentle-ai is an ecosystem configurator. One command starts a workflow with memory, SDD, skills, persona guidance, and phase-aware model routing where supported."
			data-label-es="gentle-ai es un configurador de ecosistema. Un solo comando inicia un flujo con memoria persistente, SDD, habilidades curadas, guía de persona y ruteo de modelos por fase donde está disponible.">
			gentle-ai is an ecosystem configurator. One command starts a workflow with memory, SDD, skills, persona guidance, and phase-aware model routing where supported.
		</p>

		<p class="mono mb-8 text-xs text-on-surface-variant opacity-70"
			data-label-en="Explore: Ecosystem Configurator · Workflow Docs · Interactive TUI Demo"
			data-label-es="Explora: Configurador de Ecosistema · Documentación del flujo · Demo TUI interactiva">
			Explore: Ecosystem Configurator · Workflow Docs · Interactive TUI Demo
		</p>

		<!-- GitHub stats rendered server-side -->
		<div class="will-animate flex flex-wrap items-center gap-4" data-animate="fade-up">
			<div class="flex items-center gap-2 border border-outline-variant px-3 py-1.5 transition-colors duration-200 hover:border-primary">
				<span class="material-symbols-outlined text-secondary" style="font-size: 16px;" aria-hidden="true">star</span>
				<span class="mono text-xs text-on-surface-variant" id="gh-stars">—</span>
				<span class="mono text-[10px] uppercase tracking-widest text-on-surface-variant opacity-50" data-label-en="Stars" data-label-es="Estrellas">Stars</span>
			</div>
			<div class="flex items-center gap-2 border border-outline-variant px-3 py-1.5 transition-colors duration-200 hover:border-secondary">
				<span class="material-symbols-outlined text-tertiary" style="font-size: 16px;" aria-hidden="true">fork_right</span>
				<span class="mono text-xs text-on-surface-variant" id="gh-forks">—</span>
				<span class="mono text-[10px] uppercase tracking-widest text-on-surface-variant opacity-50" data-label-en="Forks" data-label-es="Forks">Forks</span>
			</div>
			<div class="flex items-center gap-2 border border-outline-variant px-3 py-1.5 transition-colors duration-200 hover:border-tertiary">
				<span class="material-symbols-outlined text-primary" style="font-size: 16px;" aria-hidden="true">new_releases</span>
				<span class="mono text-xs text-on-surface-variant" id="gh-version">—</span>
				<span class="mono text-[10px] uppercase tracking-widest text-on-surface-variant opacity-50" data-label-en="Latest" data-label-es="Última">Latest</span>
			</div>
		</div>

		<div class="mt-8 flex flex-wrap gap-4">
			<a
				href={ctaSecondaryHref}
				class="mono flex items-center gap-2 border border-outline px-8 py-4 text-sm font-bold uppercase transition-colors duration-200 hover:bg-surface-container-low hover:border-primary"
				data-label-en="Workflow Docs"
				data-label-es="Documentación del flujo"
			>
				<span class="material-symbols-outlined" style="font-size: 18px;" aria-hidden="true">description</span>
				Workflow Docs
			</a>
			<a
				href={OFFICIAL_REPO_URL}
				target="_blank"
				rel="noopener noreferrer"
				class="mono flex items-center gap-2 border border-secondary/50 px-8 py-4 text-sm font-bold uppercase text-on-surface transition-colors duration-200 hover:border-secondary hover:bg-secondary/10"
				data-label-en="GitHub Repository"
				data-label-es="Repositorio en GitHub"
			>
				<span class="material-symbols-outlined" style="font-size: 18px;" aria-hidden="true">code</span>
				GitHub Repository
			</a>
			<a
				href="/demo"
				class="mono flex items-center gap-2 border border-primary-container bg-primary-container px-8 py-4 text-sm font-bold uppercase text-on-primary transition-all duration-200 hover:bg-secondary hover:border-secondary hover:text-background active:scale-95"
				data-label-en="Open TUI Demo"
				data-label-es="Abrir Demo TUI"
			>
				<span class="material-symbols-outlined" style="font-size: 18px;" aria-hidden="true">rocket_launch</span>
				Open TUI Demo
			</a>
		</div>
	</div>

	<!-- Right column: platform install window -->
	<div data-animate="slide-right" class="will-animate w-full lg:col-span-7 lg:col-start-6 lg:justify-self-end lg:max-w-[740px] xl:max-w-[780px]">
		<div class="rounded-xl border border-primary/40 bg-surface-container-lowest p-1.5 shadow-[0_0_0_1px_rgba(245,245,245,0.06)]" data-hero-install-tabs data-copy-scope>
			<div class="overflow-hidden rounded-md border border-outline-variant bg-surface-container-low">
				<div class="flex flex-wrap items-center gap-2 border-b border-outline-variant bg-surface-container-high px-5 py-3">
					<span class="mono text-[11px] uppercase tracking-widest text-primary" data-label-en="Install gentle-ai" data-label-es="Instalar gentle-ai">Install gentle-ai</span>
					<span class="mono ml-auto bg-primary/15 px-2.5 py-1 text-[11px] text-primary" data-label-en="Platform-specific commands" data-label-es="Comandos por plataforma">Platform-specific commands</span>
				</div>

				<div class="border-b border-outline-variant bg-surface-container-lowest px-4 py-3" role="tablist" aria-label="Installation methods" data-aria-label-en="Installation methods" data-aria-label-es="Métodos de instalación">
					<div class="flex flex-wrap gap-2">
						<button
							type="button"
							class="mono border border-primary/50 bg-primary/10 px-3.5 py-2 text-[11px] uppercase tracking-wider text-primary transition-colors"
							role="tab"
							aria-selected="true"
							aria-controls="hero-install-panel-brew"
							id="hero-install-tab-brew"
							data-install-tab="brew"
							data-label-en="macOS / Linux (brew)"
							data-label-es="macOS / Linux (brew)"
							tabindex="0"
						>
							macOS / Linux (brew)
						</button>
						<button
							type="button"
							class="mono border border-outline-variant px-3.5 py-2 text-[11px] uppercase tracking-wider text-on-surface-variant transition-colors hover:border-primary hover:text-primary"
							role="tab"
							aria-selected="false"
							aria-controls="hero-install-panel-go"
							id="hero-install-tab-go"
							data-install-tab="go"
							data-label-en="Any OS (go install)"
							data-label-es="Cualquier SO (go install)"
							tabindex="-1"
						>
							Any OS (go install)
						</button>
						<button
							type="button"
							class="mono border border-outline-variant px-3.5 py-2 text-[11px] uppercase tracking-wider text-on-surface-variant transition-colors hover:border-primary hover:text-primary"
							role="tab"
							aria-selected="false"
							aria-controls="hero-install-panel-scoop"
							id="hero-install-tab-scoop"
							data-install-tab="scoop"
							data-label-en="Windows (scoop)"
							data-label-es="Windows (scoop)"
							tabindex="-1"
						>
							Windows (scoop)
						</button>
					</div>
				</div>

				<div class="relative min-h-[260px] bg-surface-container-lowest p-6 mono text-sm leading-loose text-on-surface-variant">
					<CopyButton
						class="absolute right-6 top-5 h-8 w-8"
						target="[data-install-panel][aria-hidden='false']"
						ariaLabel="Copy installation commands"
						ariaLabelEs="Copiar comandos de instalación"
					/>

					<div
						id="hero-install-panel-brew"
						role="tabpanel"
						aria-labelledby="hero-install-tab-brew"
						aria-hidden="false"
						class="block pt-10"
						data-install-panel="brew"
						data-copy-text="brew tap Gentleman-Programming/homebrew-tap
brew install gentle-ai
gentle-ai"
					>
						<pre class="text-[14px] md:text-[15px]">brew tap <span class="text-primary">Gentleman-Programming/homebrew-tap</span>
brew install <span class="text-primary">gentle-ai</span>
<span class="text-secondary">gentle-ai</span></pre>
					</div>

					<div
						id="hero-install-panel-go"
						role="tabpanel"
						aria-labelledby="hero-install-tab-go"
						aria-hidden="true"
						class="hidden pt-10"
						data-install-panel="go"
						data-copy-text="go install github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest
gentle-ai"
					>
						<pre class="text-[14px] md:text-[15px]">go install <span class="text-primary">github.com/gentleman-programming/gentle-ai/cmd/gentle-ai@latest</span>
<span class="text-secondary">gentle-ai</span></pre>
					</div>

					<div
						id="hero-install-panel-scoop"
						role="tabpanel"
						aria-labelledby="hero-install-tab-scoop"
						aria-hidden="true"
						class="hidden pt-10"
						data-install-panel="scoop"
						data-copy-text="scoop bucket add gentleman https://github.com/Gentleman-Programming/scoop-bucket
scoop install gentle-ai
gentle-ai"
					>
						<pre class="text-[14px] md:text-[15px]">scoop bucket add <span class="text-primary">gentleman</span> https://github.com/Gentleman-Programming/scoop-bucket
scoop install <span class="text-primary">gentle-ai</span>
<span class="text-secondary">gentle-ai</span></pre>
					</div>

					<a href="#install" class="mt-5 inline-flex items-center gap-2 border border-outline px-3.5 py-2.5 text-[11px] uppercase tracking-wide transition-colors duration-200 hover:border-primary hover:bg-surface-container-low"
						data-label-en="View full install matrix"
						data-label-es="Ver matriz completa de instalación">
						<span class="material-symbols-outlined" style="font-size: 16px;" aria-hidden="true">terminal</span>
						View full install matrix
					</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script is:inline>
	function initHeroInstallTabs() {
		const detectInstallTab = () => {
			if (typeof navigator === 'undefined') return 'go';

			const sources = [];
			if (navigator.userAgentData && typeof navigator.userAgentData.platform === 'string') {
				sources.push(navigator.userAgentData.platform);
			}
			if (typeof navigator.platform === 'string') {
				sources.push(navigator.platform);
			}
			if (typeof navigator.userAgent === 'string') {
				sources.push(navigator.userAgent);
			}

			const fingerprint = sources.join(' ').toLowerCase();
			if (!fingerprint) return 'go';

			if (fingerprint.includes('win')) return 'scoop';
			if (
				fingerprint.includes('mac') ||
				fingerprint.includes('darwin') ||
				fingerprint.includes('linux') ||
				fingerprint.includes('x11')
			) {
				return 'brew';
			}

			return 'go';
		};

		const groups = Array.from(document.querySelectorAll('[data-hero-install-tabs]'));

		groups.forEach((group) => {
			if (group.dataset.heroInstallTabsInit) return;
			group.dataset.heroInstallTabsInit = 'true';

			const tabs = Array.from(group.querySelectorAll('[data-install-tab]'));
			const panels = Array.from(group.querySelectorAll('[data-install-panel]'));

			const activate = (tabId) => {
				tabs.forEach((tab) => {
					const isActive = tab.dataset.installTab === tabId;
					tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
					tab.setAttribute('tabindex', isActive ? '0' : '-1');
					tab.classList.toggle('border-primary/50', isActive);
					tab.classList.toggle('bg-primary/10', isActive);
					tab.classList.toggle('text-primary', isActive);
					tab.classList.toggle('border-outline-variant', !isActive);
					tab.classList.toggle('text-on-surface-variant', !isActive);
				});

				panels.forEach((panel) => {
					const isActive = panel.dataset.installPanel === tabId;
					panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
					panel.classList.toggle('block', isActive);
					panel.classList.toggle('hidden', !isActive);
				});
			};

			const activateByIndex = (index) => {
				const target = tabs[index];
				if (!target?.dataset.installTab) return;
				activate(target.dataset.installTab);
				target.focus();
			};

			const autoSelectedTab = detectInstallTab();
			activate(tabs.some((tab) => tab.dataset.installTab === autoSelectedTab) ? autoSelectedTab : 'go');

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					if (tab.dataset.installTab) activate(tab.dataset.installTab);
				});

				tab.addEventListener('keydown', (event) => {
					const index = tabs.indexOf(tab);
					if (event.key === 'ArrowRight') {
						event.preventDefault();
						activateByIndex((index + 1) % tabs.length);
					}
					if (event.key === 'ArrowLeft') {
						event.preventDefault();
						activateByIndex((index - 1 + tabs.length) % tabs.length);
					}
					if (event.key === 'Home') {
						event.preventDefault();
						activateByIndex(0);
					}
					if (event.key === 'End') {
						event.preventDefault();
						activateByIndex(tabs.length - 1);
					}
				});
			});
		});
	}

	initHeroInstallTabs();
	document.addEventListener('astro:page-load', initHeroInstallTabs);

	function fetchGithubStats() {
		var REPO = 'Gentleman-Programming/gentle-ai';
		var CACHE_KEY = 'gl-github-stats-v1';
		var CACHE_TTL_MS = 15 * 60 * 1000;
		var stars = document.getElementById('gh-stars');
		var forks = document.getElementById('gh-forks');
		var version = document.getElementById('gh-version');
		if (!stars || !forks || !version) return;

		try {
			var cachedRaw = sessionStorage.getItem(CACHE_KEY);
			if (cachedRaw) {
				var cached = JSON.parse(cachedRaw);
				if (cached && cached.savedAt && cached.data && Date.now() - cached.savedAt < CACHE_TTL_MS) {
					stars.textContent = cached.data.stars || '—';
					forks.textContent = cached.data.forks || '—';
					version.textContent = cached.data.version || 'v0.1.0';
				}
			}
		} catch (_) {}

		Promise.all([
			fetch('https://api.github.com/repos/' + REPO, { headers: { Accept: 'application/vnd.github.v3+json' } }),
			fetch('https://api.github.com/repos/' + REPO + '/releases/latest', { headers: { Accept: 'application/vnd.github.v3+json' } })
		]).then(function(responses) {
			var next = { stars: stars.textContent || '—', forks: forks.textContent || '—', version: version.textContent || 'v0.1.0' };
			if (responses[0].ok) {
				responses[0].json().then(function(repo) {
					next.stars = repo.stargazers_count >= 1000
						? (repo.stargazers_count / 1000).toFixed(1) + 'k'
						: String(repo.stargazers_count);
					next.forks = String(repo.forks_count);
					stars.textContent = next.stars;
					forks.textContent = next.forks;
					try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ savedAt: Date.now(), data: next })); } catch (_) {}
				});
			}
			if (responses[1].ok) {
				responses[1].json().then(function(release) {
					next.version = release.tag_name || 'v0.1.0';
					version.textContent = next.version;
					try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ savedAt: Date.now(), data: next })); } catch (_) {}
				});
			} else {
				version.textContent = next.version || 'v0.1.0';
			}
		}).catch(function() {
			if (stars.textContent === '—') stars.textContent = '…';
			if (forks.textContent === '—') forks.textContent = '…';
			if (version.textContent === '—') version.textContent = 'v0.1.0';
		});
	}

	fetchGithubStats();
	document.addEventListener('astro:page-load', fetchGithubStats);
</script>
