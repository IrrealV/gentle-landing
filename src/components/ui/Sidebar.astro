---
interface SidebarItem {
	label: string;
	href: string;
	active?: boolean;
}

interface SidebarGroup {
	title: string;
	items: SidebarItem[];
}

interface Props {
	header?: string;
	groups: SidebarGroup[];
	ariaLabel?: string;
	class?: string;
}

const {
	header = 'Documentation / Root',
	groups,
	ariaLabel = 'Documentation navigation',
	class: className = '',
} = Astro.props;

const invalidItem = groups
	.flatMap((group) => group.items)
	.find((item) => !item.href.startsWith('/') && !item.href.startsWith('#'));

if (invalidItem) {
	throw new Error(`Sidebar only supports internal links. Received: ${invalidItem.href}`);
}
---

<aside class={`border border-outline-variant bg-surface-container-low ${className}`}>
	<div class="border-b border-outline-variant bg-surface-container-high p-4">
		<span class="font-mono text-[10px] uppercase tracking-tighter text-on-surface-variant">{header}</span>
	</div>

	<nav class="space-y-8 p-6" aria-label={ariaLabel}>
		{
			groups.map((group) => (
				<section>
					<h3 class="mb-4 font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">{group.title}</h3>
					<ul class="space-y-1">
						{
							group.items.map((item) => (
								<li>
									<a
										href={item.href}
										class:list={[
											'flex items-center gap-3 px-3 py-2 text-sm font-label transition-colors',
											item.active
												? 'border-l-2 border-primary bg-surface-container-high text-primary'
												: 'text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface',
										]}
									>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</section>
			))
		}
	</nav>
</aside>
