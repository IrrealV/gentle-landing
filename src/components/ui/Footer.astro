---
const resources = [
	{ label: 'Documentation', href: '/docs' },
	{ label: 'How It Works', href: '/how-it-works' },
	{ label: 'Features', href: '/features' },
];

const community = [
	{ label: 'Community Guide', href: '/docs' },
	{ label: 'Contribution Workflow', href: '/how-it-works' },
	{ label: 'Configuration Center', href: '/configurator' },
];
---

<footer data-home-section="footer" class="w-full border-t border-outline-variant bg-background px-8 py-12">
	<div class="mx-auto flex w-full max-w-7xl flex-col gap-10">
		<div class="grid grid-cols-1 gap-10 md:grid-cols-3">
			<!-- Brand -->
			<div class="space-y-4">
				<div class="flex items-center gap-2">
					<span class="flex h-6 w-6 items-center justify-center border border-outline-variant bg-surface-container-low text-primary">
						<span class="material-symbols-outlined text-sm" aria-hidden="true">terminal</span>
					</span>
					<span class="font-['Space_Grotesk'] text-xl font-bold uppercase tracking-tighter text-primary">GENTLE-AI</span>
				</div>
				<p class="font-mono text-xs text-on-surface-variant">© 2026 Gentle-AI Platform</p>
				<p class="font-mono text-[10px] uppercase tracking-widest text-on-surface-variant opacity-60"
					data-label-en="One command. Any agent. Any OS."
					data-label-es="Un comando. Cualquier agente. Cualquier OS.">
					One command. Any agent. Any OS.
				</p>
				<p class="font-mono text-[10px] text-on-surface-variant opacity-50">Local-first · Portable setup · Issue-First Workflow</p>
			</div>

			<!-- Resources -->
			<div>
				<h4 class="mb-4 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
					data-label-en="Resources"
					data-label-es="Recursos">Resources</h4>
				<ul class="space-y-3">
					{
						resources.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-mono text-xs text-on-surface-variant underline decoration-dotted opacity-80 transition-all duration-200 hover:text-primary hover:opacity-100"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Community -->
			<div>
				<h4 class="mb-4 font-mono text-[10px] uppercase tracking-widest text-on-surface-variant"
					data-label-en="Community"
					data-label-es="Comunidad">Community</h4>
				<ul class="space-y-3">
					{
						community.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-mono text-xs text-on-surface-variant underline decoration-dotted opacity-80 transition-all duration-200 hover:text-primary hover:opacity-100"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="flex flex-col items-center justify-between gap-4 border-t border-outline-variant pt-6 md:flex-row">
			<span class="font-mono text-[10px] uppercase tracking-widest text-on-surface-variant opacity-50">
				Gentle-AI Platform · Conventional Commits · Issue-First
			</span>
			<div class="flex items-center gap-4">
				<a
					href="/docs"
					class="flex h-10 w-10 items-center justify-center border border-outline-variant transition-colors duration-200 hover:border-primary"
					aria-label="Documentation"
				>
					<span class="material-symbols-outlined text-on-surface-variant" aria-hidden="true">terminal</span>
				</a>
				<a
					href="/features"
					class="flex h-10 w-10 items-center justify-center border border-outline-variant transition-colors duration-200 hover:border-secondary"
					aria-label="Features"
				>
					<span class="material-symbols-outlined text-on-surface-variant" aria-hidden="true">extension</span>
				</a>
			</div>
		</div>
	</div>
</footer>
