---
// InteractiveTUI.astro
// Faithful browser reconstruction of the gentle-ai Bubbletea welcome flow.
---

<div
	id="tui-root"
	data-initialized="false"
	tabindex="0"
	role="region"
	aria-label="Interactive Gentle-AI terminal demo (browser reconstruction)"
	class="tui-shell"
>
	<div class="tui-titlebar">
		<span class="tui-dot tui-dot-red" aria-hidden="true"></span>
		<span class="tui-dot tui-dot-gold" aria-hidden="true"></span>
		<span class="tui-dot tui-dot-green" aria-hidden="true"></span>
		<span class="tui-title" data-label-en="gentle-ai — zsh" data-label-es="gentle-ai — zsh">gentle-ai — zsh</span>
	</div>

	<div id="tui-body" class="tui-body">
		<div id="tui-phase-prompt" class="tui-phase">
			<div class="tui-history">$ brew tap Gentleman-Programming/homebrew-tap</div>
			<div class="tui-history">$ brew install gentle-ai</div>
			<div class="tui-prompt-line">
				<span class="tui-prompt-arrow">➜</span>
				<span class="tui-prompt-home"> ~ </span>
				<span id="tui-typed" class="tui-text"></span>
				<span id="tui-cursor" class="tui-cursor">█</span>
			</div>
		</div>

		<div id="tui-phase-menu" class="tui-phase" hidden>
			<div id="tui-logo" class="tui-logo" aria-hidden="true"></div>
			<div id="tui-tagline" class="tui-tagline"></div>
			<div class="tui-disclaimer" data-label-en="Faithful browser reconstruction · representative states" data-label-es="Reconstrucción fiel en navegador · estados representativos">Faithful browser reconstruction · representative states</div>
			<h2 class="tui-heading" data-label-en="Menu" data-label-es="Menú">Menu</h2>
			<div id="tui-options" class="tui-options" role="listbox" aria-label="Gentle-AI menu options"></div>
			<div class="tui-help"><span class="tui-help-desktop" data-label-en="j/k: navigate • enter: select • q: quit" data-label-es="j/k: navegar • enter: seleccionar • q: salir">j/k: navigate • enter: select • q: quit</span><span class="tui-help-mobile" data-label-en="tap an option to continue" data-label-es="toca una opción para continuar">tap an option to continue</span></div>
		</div>

		<div id="tui-phase-screen" class="tui-phase" hidden>
			<div id="tui-screen" class="tui-screen" aria-live="polite"></div>
			<div id="tui-restart-hint" class="tui-restart-hint" hidden data-i18n-en="press <span>r</span> to restart demo" data-i18n-es="pulsa <span>r</span> para reiniciar la demo">press <span>r</span> to restart demo</div>
		</div>
	</div>
</div>

<style>
	.tui-shell {
		font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
		background: #191724;
		border: 1px solid #26233a;
		overflow: hidden;
		width: 100%;
		opacity: 0;
		transition: opacity 0.35s ease;
		max-width: 760px;
		margin: 0 auto;
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.6);
		color: #e0def4;
	}

	.tui-titlebar {
		background: #1f1d2e;
		border-bottom: 1px solid #26233a;
		padding: 10px 16px;
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.tui-dot {
		width: 12px;
		height: 12px;
		display: inline-block;
	}

	.tui-dot-red { background: #eb6f92; }
	.tui-dot-gold { background: #f6c177; }
	.tui-dot-green { background: #9ccfd8; }

	.tui-title {
		margin-left: 12px;
		font-size: 12px;
		color: #6e6a86;
		letter-spacing: 0.08em;
	}

	.tui-body {
		padding: 24px 28px;
		min-height: 420px;
	}

	.tui-phase[hidden] { display: none; }

	.tui-history {
		color: #908caa;
		font-size: 12px;
		line-height: 1.6;
	}

	.tui-history + .tui-history { margin-bottom: 12px; }

	.tui-prompt-line {
		display: flex;
		align-items: center;
		font-size: 14px;
	}

	.tui-prompt-arrow { color: #9ccfd8; }
	.tui-prompt-home { color: #c4a7e7; }
	.tui-cursor {
		animation: tui-blink 1s step-end infinite;
	}

	.tui-logo {
		margin-bottom: 16px;
		font-size: 9px;
		line-height: 1.25;
		white-space: pre;
	}

	.tui-logo-line {
		display: block;
	}

	.tui-tagline {
		color: #908caa;
		font-size: 12px;
		margin-bottom: 8px;
		letter-spacing: 0.04em;
	}

	.tui-disclaimer {
		color: #6e6a86;
		font-size: 10px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin-bottom: 14px;
	}

	.tui-heading {
		margin: 0 0 12px 0;
		color: #c4a7e7;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.06em;
	}

	.tui-options,
	.tui-screen-options {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.tui-option,
	.tui-line-option {
		border: 0;
		background: transparent;
		padding: 0;
		margin: 0;
		font: inherit;
		color: #e0def4;
		text-align: left;
		cursor: pointer;
		white-space: pre-wrap;
	}

	.tui-option-active,
	.tui-line-option-active {
		color: #c4a7e7;
		font-weight: 700;
	}

	.tui-help,
	.tui-subhelp,
	.tui-restart-hint {
		color: #6e6a86;
		font-size: 11px;
		letter-spacing: 0.04em;
	}

	.tui-help,
	.tui-restart-hint {
		border-top: 1px solid #26233a;
		padding-top: 12px;
		margin-top: 16px;
	}

	.tui-help-mobile {
		display: none;
	}

	@media (max-width: 767px) {
		.tui-help-desktop {
			display: none;
		}
		.tui-help-mobile {
			display: inline;
		}
	}


	.tui-restart-hint span {
		color: #c4a7e7;
	}

	.tui-screen-title {
		color: #c4a7e7;
		font-size: 14px;
		font-weight: 700;
		margin-bottom: 16px;
	}

	.tui-screen-copy,
	.tui-screen-meta,
	.tui-screen-block,
	.tui-screen-list,
	.tui-screen-list div,
	.tui-screen-pane,
	.tui-preview-body,
	.tui-progress-log {
		font-size: 12px;
		line-height: 1.7;
	}

	.tui-muted { color: #908caa; }
	.tui-overlay { color: #6e6a86; }
	.tui-success { color: #9ccfd8; }
	.tui-warning { color: #f1ca93; }
	.tui-danger { color: #eb6f92; }
	.tui-lavender { color: #c4a7e7; }
	.tui-mauve { color: #ebbcba; }

	.tui-frame {
		border: 3px double #c4a7e7;
		padding: 16px 18px;
	}

	.tui-panel {
		border: 1px solid #6e6a86;
		padding: 0 10px;
		background: #1f1d2e;
	}

	.tui-columns {
		display: grid;
		gap: 18px;
	}

	.tui-preview-body,
	.tui-screen-pane {
		border: 1px solid #6e6a86;
		background: #1f1d2e;
		padding: 12px;
		max-height: 220px;
		overflow: auto;
		white-space: pre-wrap;
	}

	.tui-textarea,
	.tui-input {
		width: 100%;
		border: 1px solid #6e6a86;
		background: #1f1d2e;
		color: #e0def4;
		font: inherit;
		padding: 10px 12px;
		outline: none;
		resize: none;
	}

	.tui-textarea:focus,
	.tui-input:focus,
	.tui-shell:focus {
		box-shadow: inset 0 0 0 1px #c4a7e7;
	}

	.tui-progress-bar {
		display: flex;
		margin-bottom: 8px;
	}

	.tui-progress-filled { color: #9ccfd8; }
	.tui-progress-empty { color: #6e6a86; }

	.tui-screen-list { margin: 14px 0; }

	.tui-action-options {
		margin-top: 14px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.tui-screen-list div,
	.tui-screen-copy p,
	.tui-screen-copy ul,
	.tui-screen-copy li,
	.tui-screen-copy pre {
		margin: 0;
	}

	.tui-screen-copy ul {
		padding-left: 18px;
	}

	.tui-selection-block {
		margin-bottom: 12px;
	}

	@keyframes tui-blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}
</style>

