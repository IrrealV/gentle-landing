		function renderQuitScreen() {
			return { title: '', body: '', help: '' };
		}

		function renderDetail() {
			phasePrompt.hidden = true;
			phaseMenu.hidden = true;
			phaseScreen.hidden = false;

			const ctx = state.detail;
			if (!ctx) return;

			let screen;
			switch (ctx.flow) {
				case 'install': screen = renderInstallScreen(ctx); break;
				case 'upgrade': screen = renderUpgradeScreen(ctx); break;
				case 'sync': screen = renderSyncScreen(ctx); break;
				case 'upgrade-sync': screen = renderUpgradeSyncScreen(ctx); break;
				case 'models': screen = renderModelsScreen(ctx); break;
				case 'builder': screen = renderBuilderScreen(ctx); break;
				case 'backups': screen = renderBackupsScreen(ctx); break;
				case 'quit': screen = renderQuitScreen(ctx); break;
				default: screen = { title: '', body: '', help: '' };
			}

			const wrapperClass = screen.framed ? 'tui-frame' : '';
			const actionOptions = Array.isArray(screen.options) && screen.options.length
				? `<div class="tui-action-options">${screen.options.map((option, index) => {
					const optionCursor = Number.isInteger(screen.optionCursor) ? screen.optionCursor : (Number.isInteger(ctx.cursor) ? ctx.cursor : -1);
					return optionRow(tx(option), optionCursor === index);
				}).join('')}</div>`
				: '';
			const localizedTitle = screen.title ? tx(screen.title) : '';
			const localizedBody = txHtml(screen.body || '');
			const localizedHelp = screen.help ? tx(screen.help) : '';
			screenEl.innerHTML = `<div class="${wrapperClass}">${localizedTitle ? `<div class="tui-screen-title">${escapeHtml(localizedTitle)}</div>` : ''}${localizedBody}${actionOptions}${localizedHelp ? `<div class="tui-help">${escapeHtml(localizedHelp)}</div>` : ''}</div>`;
			if (ctx.flow === 'quit') {
				showRestartHint();
			} else if (ctx.step === 'complete' || ctx.step === 'result' || ctx.step?.endsWith('result')) {
				showRestartHint();
			} else {
				hideRestartHint();
			}
			bindTransientInputs();
			if (!currentTextInput()) {
				root.focus();
			}
		}

		function bindTransientInputs() {
			const textarea = document.getElementById('tui-builder-textarea');
			if (textarea) {
				textarea.addEventListener('input', (event) => {
					if (state.detail?.flow === 'builder' && state.detail.step === 'prompt') {
						state.detail.prompt = event.currentTarget.value;
					}
				}, { signal: active.signal });
				scheduleTimeout(() => textarea.focus(), 0);
			}
			const renameInput = document.getElementById('tui-backup-rename-input');
			if (renameInput) {
				renameInput.addEventListener('input', (event) => {
					if (state.detail?.flow === 'backups' && state.detail.step === 'rename') {
						state.detail.renameValue = event.currentTarget.value;
					}
				}, { signal: active.signal });
				scheduleTimeout(() => renameInput.focus(), 0);
			}
		}

		function beginFlow(optionId) {
			clearScheduled();
			state.phase = 'detail';
			state.detail = initialDetail(optionId);
			renderDetail();
			const ctx = state.detail;
			if (!ctx) return;
			if (ctx.flow === 'upgrade' && ctx.step === 'checking') {
				setupAutoStep(ctx, 900, 'ready');
			}
		}

		function backToMenu() {
			clearScheduled();
			state.phase = 'menu';
			state.detail = null;
			renderMenu();
		}

		function restartDemo() {
			clearScheduled();
			hideRestartHint();
			state.phase = 'prompt';
			state.mainCursor = 0;
			state.detail = null;
			phaseScreen.hidden = true;
			phaseMenu.hidden = true;
			phasePrompt.hidden = false;
			typedEl.textContent = '';
			cursorEl.style.display = '';
			startObserver();
		}

		function handleMenuKey(event) {
			if (event.key === 'ArrowDown' || event.key === 'j') {
				event.preventDefault();
				state.mainCursor = (state.mainCursor + 1) % MAIN_OPTIONS.length;
				renderMenu();
				return;
			}
			if (event.key === 'ArrowUp' || event.key === 'k') {
				event.preventDefault();
				state.mainCursor = (state.mainCursor - 1 + MAIN_OPTIONS.length) % MAIN_OPTIONS.length;
				renderMenu();
				return;
			}
			if (event.key === 'Enter') {
				event.preventDefault();
				beginFlow(MAIN_OPTIONS[state.mainCursor].id);
				return;
			}
			if (event.key === 'q') {
				event.preventDefault();
				beginFlow('quit');
			}
		}

		function handleInstall(event, ctx) {
			switch (ctx.step) {
				case 'detection': {
					const options = ['Continue', 'Back'];
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % options.length; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + options.length) % options.length; renderDetail(); }
					else if (event.key === 'Enter') { event.preventDefault(); if (ctx.cursor === 0) { ctx.step = 'agents'; ctx.cursor = 0; renderDetail(); } else { backToMenu(); } }
					else if (event.key === 'Escape') { event.preventDefault(); backToMenu(); }
					break;
				}
				case 'agents': {
					const total = INSTALL_AGENTS.length + 2;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === ' ' && ctx.cursor < INSTALL_AGENTS.length) { event.preventDefault(); const id = INSTALL_AGENTS[ctx.cursor]; ctx.selectedAgents.has(id) ? ctx.selectedAgents.delete(id) : ctx.selectedAgents.add(id); renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor < INSTALL_AGENTS.length) {
							const id = INSTALL_AGENTS[ctx.cursor];
							ctx.selectedAgents.has(id) ? ctx.selectedAgents.delete(id) : ctx.selectedAgents.add(id);
							renderDetail();
						} else if (ctx.cursor === INSTALL_AGENTS.length && ctx.selectedAgents.size > 0) {
							ctx.step = 'persona';
							ctx.cursor = 0;
							renderDetail();
						} else if (ctx.cursor === INSTALL_AGENTS.length + 1) {
							ctx.step = 'detection';
							ctx.cursor = 0;
							renderDetail();
						}
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'detection'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'persona': {
					const total = PERSONAS.length + 1;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor < PERSONAS.length) { ctx.persona = PERSONAS[ctx.cursor].id; ctx.step = 'preset'; ctx.cursor = 0; renderDetail(); }
						else { ctx.step = 'agents'; ctx.cursor = 0; renderDetail(); }
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'agents'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'preset': {
					const total = PRESETS.length + 1;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor < PRESETS.length) {
							ctx.preset = PRESETS[ctx.cursor].id;
							if (ctx.selectedAgents.has('claude-code') && ctx.preset !== 'minimal') {
								ctx.step = 'claude-models';
								ctx.cursor = 0;
							} else if (ctx.selectedAgents.has('opencode') && ctx.preset !== 'minimal') {
								ctx.step = 'sdd-mode';
								ctx.cursor = 0;
							} else if (ctx.preset !== 'minimal') {
								ctx.step = 'strict-tdd';
								ctx.cursor = 0;
							} else {
								ctx.step = 'dependency';
								ctx.cursor = 0;
							}
							renderDetail();
						}
						else { ctx.step = 'persona'; ctx.cursor = 0; renderDetail(); }
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'persona'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'claude-models': {
					const total = CLAUDE_PRESETS.length;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						const choice = CLAUDE_PRESETS[ctx.cursor][0];
						if (choice === 'Back') { ctx.step = 'preset'; ctx.cursor = 0; }
						else if (choice === 'custom') {
							ctx.claudeAssignments = Object.fromEntries(CLAUDE_PHASES.slice(0, 10).map((phase) => [phase, 'sonnet']));
							ctx.step = 'claude-custom';
							ctx.cursor = 0;
						} else {
							ctx.claudePreset = choice;
							ctx.step = ctx.selectedAgents.has('opencode') ? 'sdd-mode' : 'strict-tdd';
							ctx.cursor = 0;
						}
						renderDetail();
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'preset'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'claude-custom': {
					const total = CLAUDE_PHASES.length;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						const choice = CLAUDE_PHASES[ctx.cursor];
						if (choice === 'Back') { ctx.step = 'claude-models'; ctx.cursor = 0; }
						else if (choice === 'Confirm') { ctx.step = ctx.selectedAgents.has('opencode') ? 'sdd-mode' : 'strict-tdd'; ctx.cursor = 0; }
						else {
							ctx.claudeAssignments ??= Object.fromEntries(CLAUDE_PHASES.slice(0, 10).map((phase) => [phase, 'sonnet']));
							ctx.claudeAssignments[choice] = nextAlias(ctx.claudeAssignments[choice] || 'sonnet');
						}
						renderDetail();
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'claude-models'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'sdd-mode': {
					const total = 3;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor === 0) { ctx.sddMode = 'single'; ctx.step = 'strict-tdd'; ctx.cursor = 0; }
						else if (ctx.cursor === 1) { ctx.sddMode = 'multi'; ctx.step = 'strict-tdd'; ctx.cursor = 0; }
						else { ctx.step = ctx.selectedAgents.has('claude-code') ? 'claude-models' : 'preset'; ctx.cursor = 0; }
						renderDetail();
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = ctx.selectedAgents.has('claude-code') ? 'claude-models' : 'preset'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'strict-tdd': {
					const total = 3;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor === 0) { ctx.strictTdd = true; ctx.step = 'dependency'; ctx.cursor = 0; }
						else if (ctx.cursor === 1) { ctx.strictTdd = false; ctx.step = 'dependency'; ctx.cursor = 0; }
						else { ctx.step = ctx.selectedAgents.has('opencode') ? 'sdd-mode' : (ctx.selectedAgents.has('claude-code') ? 'claude-models' : 'preset'); ctx.cursor = 0; }
						renderDetail();
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = ctx.selectedAgents.has('opencode') ? 'sdd-mode' : (ctx.selectedAgents.has('claude-code') ? 'claude-models' : 'preset'); ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'dependency': {
					const actionStart = ctx.preset === 'custom' ? INSTALL_COMPONENTS.length : 0;
					const total = actionStart + 2;
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
					else if ((event.key === ' ' || event.key === 'Enter') && ctx.preset === 'custom' && ctx.cursor < INSTALL_COMPONENTS.length) { event.preventDefault(); renderDetail(); }
					else if (event.key === 'Enter') { event.preventDefault(); if (ctx.cursor === actionStart) { ctx.step = 'review'; ctx.cursor = 0; renderDetail(); } else if (ctx.cursor === actionStart + 1) { ctx.step = ctx.preset !== 'minimal' ? 'strict-tdd' : 'preset'; ctx.cursor = 0; renderDetail(); } }
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = ctx.preset !== 'minimal' ? 'strict-tdd' : 'preset'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'review': {
					const options = ['Install', 'Back'];
					if (['ArrowDown', 'j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % options.length; renderDetail(); }
					else if (['ArrowUp', 'k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + options.length) % options.length; renderDetail(); }
					else if (event.key === 'Enter') {
						event.preventDefault();
						if (ctx.cursor === 0) { ctx.step = 'installing'; installAutoScreens(ctx); renderDetail(); }
						else { ctx.step = 'dependency'; ctx.cursor = 0; renderDetail(); }
					}
					else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'dependency'; ctx.cursor = 0; renderDetail(); }
					break;
				}
				case 'complete':
					if (event.key === 'Enter' || event.key === 'Escape') { event.preventDefault(); backToMenu(); }
					break;
			}
		}

		function handleUpgrade(event, ctx) {
			if (ctx.step === 'ready' && event.key === 'Enter') { event.preventDefault(); ctx.step = 'running'; renderDetail(); setupAutoStep(ctx, 1400, 'result'); }
			else if (ctx.step === 'result' && (event.key === 'Enter' || event.key === 'Escape')) { event.preventDefault(); backToMenu(); }
			else if (['checking', 'running'].includes(ctx.step) && event.key === 'Escape') { event.preventDefault(); backToMenu(); }
			else if (event.key === 'Escape' && ctx.step === 'ready') { event.preventDefault(); backToMenu(); }
		}

		function handleSync(event, ctx) {
			if (ctx.step === 'confirm' && event.key === 'Enter') { event.preventDefault(); ctx.step = 'running'; renderDetail(); setupAutoStep(ctx, 1200, 'result'); }
			else if (ctx.step === 'result' && (event.key === 'Enter' || event.key === 'Escape')) { event.preventDefault(); backToMenu(); }
			else if (ctx.step === 'confirm' && event.key === 'Escape') { event.preventDefault(); backToMenu(); }
		}

		function handleUpgradeSync(event, ctx) {
			if (ctx.step === 'confirm' && event.key === 'Enter') {
				event.preventDefault();
				ctx.step = 'upgrading';
				renderDetail();
				startSpinner();
				scheduleTimeout(() => {
					if (!state.detail || state.detail !== ctx || ctx.step !== 'upgrading') return;
					ctx.step = 'syncing';
					renderDetail();
				}, 1200);
				scheduleTimeout(() => {
					if (!state.detail || state.detail !== ctx || ctx.step !== 'syncing') return;
					stopSpinner();
					ctx.step = 'result';
					renderDetail();
				}, 2400);
			} else if (ctx.step === 'result' && (event.key === 'Enter' || event.key === 'Escape')) {
				event.preventDefault();
				backToMenu();
			} else if (ctx.step === 'confirm' && event.key === 'Escape') {
				event.preventDefault();
				backToMenu();
			}
		}

		function handleModels(event, ctx) {
			const max = (step) => {
				switch (step) {
					case 'entry': return 3;
					case 'claude-presets': return CLAUDE_PRESETS.length;
					case 'claude-custom': return CLAUDE_PHASES.length;
					case 'opencode-phases': return OPENCODE_PHASES.length;
					case 'provider-select': return PROVIDERS.length;
					case 'model-select': return MODELS.length;
					default: return 0;
				}
			};
			if (['entry','claude-presets','claude-custom','opencode-phases','provider-select','model-select'].includes(ctx.step)) {
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % max(ctx.step); renderDetail(); return; }
				if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + max(ctx.step)) % max(ctx.step); renderDetail(); return; }
			}
			if (ctx.step === 'entry' && event.key === 'Enter') {
				event.preventDefault();
				if (ctx.cursor === 0) { ctx.step = 'claude-presets'; ctx.cursor = 0; }
				else if (ctx.cursor === 1) { ctx.step = 'opencode-phases'; ctx.cursor = 0; }
				else { backToMenu(); return; }
				renderDetail();
				return;
			}
			if (ctx.step === 'claude-presets' && event.key === 'Enter') {
				event.preventDefault();
				const choice = CLAUDE_PRESETS[ctx.cursor][0];
				if (choice === 'Back') { ctx.step = 'entry'; ctx.cursor = 0; }
				else if (choice === 'custom') { ctx.step = 'claude-custom'; ctx.cursor = 0; }
				else { ctx.claudePreset = choice; ctx.step = 'sync-confirm'; ctx.cursor = 0; }
				renderDetail();
				return;
			}
			if (ctx.step === 'claude-custom' && event.key === 'Enter') {
				event.preventDefault();
				const choice = CLAUDE_PHASES[ctx.cursor];
				if (choice === 'Back') { ctx.step = 'claude-presets'; ctx.cursor = 0; }
				else if (choice === 'Confirm') { ctx.step = 'sync-confirm'; ctx.cursor = 0; }
				else { ctx.claudeAssignments[choice] = nextAlias(ctx.claudeAssignments?.[choice] || 'sonnet'); }
				renderDetail();
				return;
			}
			if (ctx.step === 'opencode-phases' && event.key === 'Enter') {
				event.preventDefault();
				const choice = OPENCODE_PHASES[ctx.cursor];
				if (choice === 'Back') { ctx.step = 'entry'; ctx.cursor = 0; }
				else if (choice === 'Continue') { ctx.step = 'sync-confirm'; ctx.cursor = 0; }
				else { ctx.selectedPhase = choice; ctx.step = 'provider-select'; ctx.cursor = 0; }
				renderDetail();
				return;
			}
			if (ctx.step === 'provider-select' && event.key === 'Enter') {
				event.preventDefault();
				const choice = PROVIDERS[ctx.cursor];
				if (choice === 'Back') { ctx.step = 'opencode-phases'; ctx.cursor = 0; }
				else { ctx.selectedProvider = choice; ctx.step = 'model-select'; ctx.cursor = 0; }
				renderDetail();
				return;
			}
			if (ctx.step === 'model-select' && event.key === 'Enter') {
				event.preventDefault();
				const choice = MODELS[ctx.cursor];
				if (choice === 'Back') { ctx.step = 'provider-select'; ctx.cursor = 0; }
				else {
					ctx.selectedModel = choice;
					const assignment = { provider: ctx.selectedProvider, model: choice };
					if (ctx.selectedPhase === 'Set all phases') {
						ctx.allPhasesModel = assignment;
						['explore', 'propose', 'spec', 'design', 'tasks', 'apply', 'verify', 'archive'].forEach((phase) => {
							ctx.modelAssignments[phase] = assignment;
						});
					} else {
						ctx.modelAssignments[ctx.selectedPhase] = assignment;
					}
					ctx.step = 'opencode-phases';
					ctx.cursor = 0;
				}
				renderDetail();
				return;
			}
			if (ctx.step === 'sync-confirm' && event.key === 'Enter') {
				event.preventDefault();
				ctx.step = 'sync-running';
				renderDetail();
				setupAutoStep(ctx, 1100, 'sync-result');
				return;
			}
			if (ctx.step === 'sync-result' && (event.key === 'Enter' || event.key === 'Escape')) { event.preventDefault(); backToMenu(); return; }
			if (event.key === 'Escape') {
				event.preventDefault();
				if (ctx.step === 'entry') backToMenu();
				else if (ctx.step === 'claude-presets') { ctx.step = 'entry'; ctx.cursor = 0; renderDetail(); }
				else if (ctx.step === 'claude-custom') { ctx.step = 'claude-presets'; ctx.cursor = 0; renderDetail(); }
				else if (ctx.step === 'opencode-phases') { ctx.step = 'entry'; ctx.cursor = 0; renderDetail(); }
				else if (ctx.step === 'provider-select') { ctx.step = 'opencode-phases'; ctx.cursor = 0; renderDetail(); }
				else if (ctx.step === 'model-select') { ctx.step = 'provider-select'; ctx.cursor = 0; renderDetail(); }
				else if (ctx.step === 'sync-confirm') { ctx.step = 'entry'; ctx.cursor = 0; renderDetail(); }
			}
		}

		function handleBuilder(event, ctx) {
			const engineOptions = ['claude-code', 'opencode', 'gemini-cli', 'codex', 'Back'];
			if (ctx.step === 'engine') {
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % engineOptions.length; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + engineOptions.length) % engineOptions.length; renderDetail(); }
				else if (event.key === 'Enter') { event.preventDefault(); const choice = engineOptions[ctx.cursor]; if (choice === 'Back') backToMenu(); else { ctx.engine = choice; ctx.step = 'prompt'; renderDetail(); } }
				else if (event.key === 'Escape') { event.preventDefault(); backToMenu(); }
				return;
			}
			if (ctx.step === 'prompt') {
				const activeInput = document.getElementById('tui-builder-textarea');
				if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'engine'; ctx.cursor = 0; renderDetail(); return; }
				if ((event.key === 'Tab' || (event.key === 'Enter' && event.ctrlKey)) && activeInput && activeInput.value.trim()) {
					event.preventDefault();
					ctx.prompt = activeInput.value.trim();
					ctx.step = 'sdd';
					ctx.cursor = 0;
					renderDetail();
				}
				return;
			}
			if (ctx.step === 'sdd') {
				const sddOptions = ['Standalone — no SDD integration', 'New SDD Phase — add a new phase to the SDD graph', 'Phase Support — enhance an existing SDD phase', 'Back'];
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % sddOptions.length; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + sddOptions.length) % sddOptions.length; renderDetail(); }
				else if (event.key === 'Enter') {
					event.preventDefault();
					if (ctx.cursor === 0) { ctx.sddMode = 'standalone'; ctx.step = 'generating'; renderDetail(); setupAutoStep(ctx, 1300, 'preview'); }
					else if (ctx.cursor === 1) { ctx.sddMode = 'new-phase'; ctx.step = 'sdd-phase'; ctx.cursor = 0; renderDetail(); }
					else if (ctx.cursor === 2) { ctx.sddMode = 'phase-support'; ctx.step = 'sdd-phase'; ctx.cursor = 0; renderDetail(); }
					else { ctx.step = 'prompt'; renderDetail(); }
				}
				else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'prompt'; renderDetail(); }
				return;
			}
			if (ctx.step === 'sdd-phase') {
				const phases = ['explore', 'propose', 'spec', 'design', 'tasks', 'apply', 'verify', 'archive', 'Back'];
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % phases.length; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + phases.length) % phases.length; renderDetail(); }
				else if (event.key === 'Enter') {
					event.preventDefault();
					if (phases[ctx.cursor] === 'Back') { ctx.step = 'sdd'; ctx.cursor = 0; renderDetail(); }
					else { ctx.sddPhase = phases[ctx.cursor]; ctx.step = 'generating'; renderDetail(); setupAutoStep(ctx, 1300, 'preview'); }
				}
				else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'sdd'; ctx.cursor = 0; renderDetail(); }
				return;
			}
			if (ctx.step === 'generating') {
				if (event.key === 'Escape') { event.preventDefault(); clearScheduled(); ctx.step = 'prompt'; renderDetail(); }
				return;
			}
			if (ctx.step === 'preview') {
				const actions = ['Install', 'Regenerate', 'Back'];
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % actions.length; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + actions.length) % actions.length; renderDetail(); }
				else if (event.key === 'Enter') {
					event.preventDefault();
					if (ctx.cursor === 0) { ctx.step = 'installing'; renderDetail(); setupAutoStep(ctx, 1200, 'complete'); }
					else if (ctx.cursor === 1) { ctx.step = 'generating'; ctx.cursor = 0; renderDetail(); setupAutoStep(ctx, 1000, 'preview'); }
					else { ctx.step = 'prompt'; ctx.cursor = 0; renderDetail(); }
				}
				else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'prompt'; ctx.cursor = 0; renderDetail(); }
				return;
			}
			if (ctx.step === 'complete' && (event.key === 'Enter' || event.key === 'Escape')) {
				event.preventDefault();
				backToMenu();
			}
		}

		function handleBackups(event, ctx) {
			const total = ctx.backups.length + 1;
			if (ctx.step === 'list') {
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % total; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + total) % total; renderDetail(); }
				else if (event.key === 'p' && ctx.cursor < ctx.backups.length) { event.preventDefault(); ctx.backups[ctx.cursor].pinned = !ctx.backups[ctx.cursor].pinned; renderDetail(); }
				else if (event.key === 'd' && ctx.cursor < ctx.backups.length) { event.preventDefault(); ctx.selected = ctx.backups[ctx.cursor]; ctx.step = 'delete-confirm'; ctx.cursor = 0; renderDetail(); }
				else if (event.key === 'r' && ctx.cursor < ctx.backups.length) { event.preventDefault(); ctx.renameTarget = ctx.backups[ctx.cursor]; ctx.renameValue = ctx.renameTarget.description || ''; ctx.step = 'rename'; renderDetail(); }
				else if (event.key === 'Enter') {
					event.preventDefault();
					if (ctx.cursor < ctx.backups.length) { ctx.selected = ctx.backups[ctx.cursor]; ctx.step = 'restore-confirm'; ctx.cursor = 0; renderDetail(); }
					else { backToMenu(); }
				}
				else if (event.key === 'Escape') { event.preventDefault(); backToMenu(); }
				return;
			}
			if (ctx.step === 'restore-confirm' || ctx.step === 'delete-confirm') {
				const actions = ctx.step === 'restore-confirm' ? ['Restore', 'Cancel'] : ['Delete', 'Cancel'];
				if (['ArrowDown','j'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor + 1) % actions.length; renderDetail(); }
				else if (['ArrowUp','k'].includes(event.key)) { event.preventDefault(); ctx.cursor = (ctx.cursor - 1 + actions.length) % actions.length; renderDetail(); }
				else if (event.key === 'Enter') {
					event.preventDefault();
					if (ctx.cursor === 0) {
						if (ctx.step === 'restore-confirm') ctx.step = 'restore-result';
						else {
							ctx.backups = ctx.backups.filter((item) => item.id !== ctx.selected.id);
							ctx.step = 'delete-result';
						}
						renderDetail();
					} else { ctx.step = 'list'; ctx.cursor = 0; renderDetail(); }
				}
				else if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'list'; ctx.cursor = 0; renderDetail(); }
				return;
			}
			if (ctx.step === 'rename') {
				const input = document.getElementById('tui-backup-rename-input');
				if (event.key === 'Escape') { event.preventDefault(); ctx.step = 'list'; ctx.cursor = 0; renderDetail(); }
				else if (event.key === 'Enter' && input) {
					event.preventDefault();
					ctx.renameTarget.description = input.value.trim() || 'renamed snapshot';
					ctx.step = 'list';
					ctx.cursor = 0;
					renderDetail();
				}
				return;
			}
			if (['restore-result','delete-result'].includes(ctx.step) && (event.key === 'Enter' || event.key === 'Escape')) {
				event.preventDefault();
				ctx.step = 'list';
				ctx.cursor = 0;
				renderDetail();
			}
		}

		function handleDetailKey(event) {
			const ctx = state.detail;
			if (!ctx) return;

			if (event.key === 'q') {
				event.preventDefault();
				state.detail = initialDetail('quit');
				renderDetail();
				return;
			}

			if (event.key === 'r' || event.key === 'R') {
				event.preventDefault();
				restartDemo();
				return;
			}

			switch (ctx.flow) {
				case 'install': handleInstall(event, ctx); break;
				case 'upgrade': handleUpgrade(event, ctx); break;
				case 'sync': handleSync(event, ctx); break;
				case 'upgrade-sync': handleUpgradeSync(event, ctx); break;
				case 'models': handleModels(event, ctx); break;
				case 'builder': handleBuilder(event, ctx); break;
				case 'backups': handleBackups(event, ctx); break;
				case 'quit': if (event.key === 'Enter' || event.key === 'Escape') { event.preventDefault(); restartDemo(); } break;
			}
		}

		function render() {
			if (state.phase === 'menu') renderMenu();
			if (state.phase === 'detail') renderDetail();
		}

		function typewrite(el, text) {
			let index = 0;
			function step() {
				if (active.signal.aborted) return;
				el.textContent += text[index] || '';
				index += 1;
				if (index < text.length) {
					scheduleTimeout(step, Math.max(30, 70 + (Math.random() * 40 - 20)));
				}
			}
			step();
		}

		function startPrompt() {
			typedEl.textContent = '';
			cursorEl.style.display = '';
			typewrite(typedEl, 'gentle-ai');
			scheduleTimeout(() => { cursorEl.style.display = 'none'; }, 1150);
			scheduleTimeout(() => {
				state.phase = 'menu';
				renderMenu();
			}, 1500);
		}

		function startObserver() {
			observer?.disconnect();
			observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						observer.disconnect();
						root.style.opacity = '1';
						scheduleTimeout(startPrompt, 350);
					}
				});
			}, { threshold: 0.35 });
			observer.observe(root);
		}

		function clickHandler(event) {
			root.focus();
			if (state.phase === 'menu') {
				const target = event.target.closest('[data-menu-index]');
				if (!target) return;
				state.mainCursor = Number(target.dataset.menuIndex);
				beginFlow(MAIN_OPTIONS[state.mainCursor].id);
			}
		}

		let root = null;
		let phasePrompt = null;
		let phaseMenu = null;
		let phaseScreen = null;
		let typedEl = null;
		let cursorEl = null;
		let logoEl = null;
		let taglineEl = null;
		let optionsEl = null;
		let screenEl = null;
		let restartHint = null;

		function bindElements() {
			root = document.getElementById('tui-root');
			phasePrompt = document.getElementById('tui-phase-prompt');
			phaseMenu = document.getElementById('tui-phase-menu');
			phaseScreen = document.getElementById('tui-phase-screen');
			typedEl = document.getElementById('tui-typed');
			cursorEl = document.getElementById('tui-cursor');
			logoEl = document.getElementById('tui-logo');
			taglineEl = document.getElementById('tui-tagline');
			optionsEl = document.getElementById('tui-options');
			screenEl = document.getElementById('tui-screen');
			restartHint = document.getElementById('tui-restart-hint');

			return Boolean(root && phasePrompt && phaseMenu && phaseScreen && typedEl && cursorEl && logoEl && taglineEl && optionsEl && screenEl && restartHint);
		}

		window[GLOBAL_KEY] ??= { cleanup: null, timers: [], spinnerInterval: null };

		let observer = null;
		let active = null;
		let state = createState();

		function cleanup() {
			clearScheduled();
			observer?.disconnect();
			observer = null;
			active?.abort();
			active = null;
			if (root) {
				root.dataset.initialized = 'false';
			}
			window[GLOBAL_KEY].cleanup = null;
		}

		function init() {
			const currentRoot = document.getElementById('tui-root');
			if (!currentRoot) return;

			if (root !== currentRoot && typeof window[GLOBAL_KEY].cleanup === 'function') {
				window[GLOBAL_KEY].cleanup();
			}

			if (!bindElements()) return;
			if (root.dataset.initialized === 'true') return;

			state = createState();
			active = new AbortController();
			root.dataset.initialized = 'true';
			window[GLOBAL_KEY].cleanup = cleanup;

			root.addEventListener('keydown', (event) => {
				const activeInput = currentTextInput();
				if (activeInput && document.activeElement === activeInput) {
					if (!(event.key === 'Escape' || event.key === 'Tab' || (event.key === 'Enter' && event.ctrlKey))) {
						return;
					}
				}
				if (state.phase === 'menu') handleMenuKey(event);
				if (state.phase === 'detail') handleDetailKey(event);
			}, { signal: active.signal });

			root.addEventListener('click', clickHandler, { signal: active.signal });
			document.addEventListener('gl:lang-change', (event) => {
				const nextLang = sanitizeLang(event?.detail?.lang || document.documentElement?.dataset?.lang);
				if (nextLang === currentLang) return;
				currentLang = nextLang;
				render();
			}, { signal: active.signal });
			document.addEventListener('astro:before-swap', cleanup, { signal: active.signal });
			document.addEventListener('astro:page-unload', cleanup, { signal: active.signal });
			startObserver();
		}

		function tryInit() {
			if (!document.getElementById('tui-root')) return;
			init();
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', tryInit, { once: true });
		} else {
			tryInit();
		}

		document.addEventListener('astro:page-load', tryInit);
	})();
</script>
