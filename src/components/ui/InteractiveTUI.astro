		function tx(value) {
			if (!value || currentLang !== 'es') return value;
			return LABELS_ES[value] || value;
		}

		function txHtml(value) {
			if (!value || currentLang !== 'es') return value;
			return HTML_ES_REPLACEMENTS.reduce((acc, [en, es]) => acc.replaceAll(en, es), value);
		}

		const GLOBAL_KEY = '__gentleLandingInteractiveTui';
		const CLAUDE_ASSIGNMENT_ALIASES = ['opus', 'sonnet', 'haiku'];

		function escapeHtml(value) {
			return String(value)
				.replaceAll('&', '&amp;')
				.replaceAll('<', '&lt;')
				.replaceAll('>', '&gt;')
				.replaceAll('"', '&quot;');
		}

		function logoColor(index) {
			const band = Math.floor((index * LOGO_BANDS.length) / LOGO_LINES.length);
			return LOGO_BANDS[Math.min(band, LOGO_BANDS.length - 1)];
		}

		function renderLogoHtml() {
			return LOGO_LINES.map((line, index) => `<span class="tui-logo-line" style="color:${logoColor(index)}">${escapeHtml(line)}</span>`).join('');
		}

		function optionRow(label, active) {
			const localizedLabel = tx(label);
			return `<div class="${active ? 'tui-option tui-option-active' : 'tui-option'}">${escapeHtml(active ? CURSOR + localizedLabel : '  ' + localizedLabel)}</div>`;
		}

		function checkboxRow(label, checked, active) {
			const prefix = checked ? '[x]' : '[ ]';
			return optionRow(`${prefix} ${label}`, active);
		}

		function radioRow(label, checked, active) {
			const prefix = checked ? '(•)' : '( )';
			return optionRow(`${prefix} ${label}`, active);
		}

		function nextAlias(current) {
			const index = CLAUDE_ASSIGNMENT_ALIASES.indexOf(current);
			return CLAUDE_ASSIGNMENT_ALIASES[(index + 1) % CLAUDE_ASSIGNMENT_ALIASES.length] || 'sonnet';
		}

		function panel(content) {
			return `<div class="tui-panel">${content}</div>`;
		}

		function progressBar(percent) {
			const filled = Math.max(0, Math.min(30, Math.floor((percent * 30) / 100)));
			return `<div class="tui-progress-bar"><span class="tui-progress-filled">${'█'.repeat(filled)}</span><span class="tui-progress-empty">${'░'.repeat(30 - filled)}</span></div>`;
		}

		function createState() {
			return {
				phase: 'prompt',
				mainCursor: 0,
				detail: null,
				spinner: 0
			};
		}

		function cloneBackups() {
			return BACKUPS.map((item) => ({ ...item }));
		}

		function initialDetail(flow) {
			switch (flow) {
				case 'install':
					return { flow, step: 'detection', cursor: 0, selectedAgents: new Set(['claude-code', 'opencode']), persona: 'gentleman', preset: 'full-gentleman', sddMode: 'multi', strictTdd: false, claudePreset: 'balanced', percent: 0, logs: [] };
				case 'upgrade':
					return { flow, step: 'checking', cursor: 0, percent: 0 };
				case 'sync':
					return { flow, step: 'confirm', cursor: 0 };
				case 'upgrade-sync':
					return { flow, step: 'confirm', cursor: 0 };
				case 'models':
					return { flow, step: 'entry', cursor: 0, claudePreset: 'balanced', claudeAssignments: Object.fromEntries(CLAUDE_PHASES.slice(0, 10).map((phase) => [phase, 'sonnet'])), selectedPhase: 'Set all phases', selectedProvider: 'Anthropic', selectedModel: 'claude-sonnet-4-5', modelAssignments: {}, allPhasesModel: null };
				case 'builder':
					return { flow, step: 'engine', cursor: 0, engine: 'claude-code', prompt: '', sddMode: 'standalone', sddPhase: 'explore' };
				case 'backups':
					return { flow, step: 'list', cursor: 0, backups: cloneBackups(), renameValue: '', renameTarget: null, selected: null };
				case 'quit':
					return { flow, step: 'silent' };
				default:
					return null;
			}
		}

		function currentTextInput() {
			return document.getElementById('tui-builder-textarea') || document.getElementById('tui-backup-rename-input');
		}

		function setupAutoStep(ctx, delay, nextStep, mutate) {
			stopSpinner();
			startSpinner();
			scheduleTimeout(() => {
				if (!state.detail || state.detail !== ctx) return;
				stopSpinner();
				if (typeof mutate === 'function') mutate(ctx);
				ctx.step = nextStep;
				render();
				if (ctx.flow === 'install' && nextStep === 'complete') {
					showRestartHint();
				}
			}, delay);
		}

		function installAutoScreens(ctx) {
			if (ctx.step === 'installing') {
				ctx.percent = 10;
				ctx.logs = ['Preparing install pipeline…'];
				const checkpoints = [
					{ at: 220, percent: 22, line: 'Writing agent configs from templates…' },
					{ at: 520, percent: 41, line: 'Injecting SDD orchestrator and phase prompts…' },
					{ at: 820, percent: 68, line: 'Registering MCP servers and memory hooks…' },
					{ at: 1120, percent: 86, line: 'Merging skills and verifying permissions…' },
					{ at: 1500, percent: 100, line: 'Finalizing ecosystem install…' }
				];
				startSpinner();
				checkpoints.forEach((point) => {
					scheduleTimeout(() => {
						if (!state.detail || state.detail !== ctx || ctx.step !== 'installing') return;
						ctx.percent = point.percent;
						ctx.logs = [...ctx.logs, point.line];
						render();
					}, point.at);
				});
				scheduleTimeout(() => {
					if (!state.detail || state.detail !== ctx || ctx.step !== 'installing') return;
					stopSpinner();
					ctx.step = 'complete';
					render();
					showRestartHint();
				}, 1800);
			}
		}

		function startSpinner() {
			if (window[GLOBAL_KEY].spinnerInterval) return;
			window[GLOBAL_KEY].spinnerInterval = window.setInterval(() => {
				state.spinner = (state.spinner + 1) % SPINNER.length;
				render();
			}, 120);
		}

		function stopSpinner() {
			if (window[GLOBAL_KEY].spinnerInterval) {
				clearInterval(window[GLOBAL_KEY].spinnerInterval);
				window[GLOBAL_KEY].spinnerInterval = null;
			}
		}

		function scheduleTimeout(fn, ms) {
			const id = window.setTimeout(() => {
				window[GLOBAL_KEY].timers = window[GLOBAL_KEY].timers.filter((timer) => timer !== id);
				fn();
			}, ms);
			window[GLOBAL_KEY].timers.push(id);
		}

		function clearScheduled() {
			(window[GLOBAL_KEY].timers || []).forEach((id) => clearTimeout(id));
			window[GLOBAL_KEY].timers = [];
			stopSpinner();
		}

		function showRestartHint() {
			restartHint.hidden = false;
		}

		function hideRestartHint() {
			restartHint.hidden = true;
		}

		function renderMenu() {
			phasePrompt.hidden = true;
			phaseScreen.hidden = true;
			phaseMenu.hidden = false;
			logoEl.innerHTML = renderLogoHtml();
			taglineEl.textContent = txHtml(`AI Gentle Stack ${VERSION} — One command. Any agent. Any OS.`);
			optionsEl.innerHTML = MAIN_OPTIONS.map((option, index) => optionRow(option.label, index === state.mainCursor)).join('');
			Array.from(optionsEl.children).forEach((child, index) => {
				child.dataset.menuIndex = String(index);
			});
			root.focus();
		}

