---
interface SidebarItem {
	label: string;
	href: string;
	active?: boolean;
}

interface SidebarGroup {
	title: string;
	items: SidebarItem[];
}

interface Props {
	title?: string;
	items?: SidebarItem[];
	groups?: SidebarGroup[];
	ariaLabel?: string;
	class?: string;
}

const { title = 'Documentation', items = [], groups = [], ariaLabel = 'Documentation navigation', class: className = '' } =
	Astro.props;

const resolvedGroups = groups.length > 0 ? groups : [{ title, items }];

const invalidItem = resolvedGroups
	.flatMap((group) => group.items)
	.find((item) => !item.href.startsWith('/') && !item.href.startsWith('#'));

if (invalidItem) {
	throw new Error(`Sidebar only supports internal links. Received: ${invalidItem.href}`);
}
---

<aside class={`section-box radius-brutal p-4 ${className}`}>
	<p class="mono border-b-hairline pb-3 text-[11px] uppercase tracking-[0.22em] text-primary-fixed">{title}</p>

	<nav class="space-y-6 pt-3" aria-label={ariaLabel}>
		{
			resolvedGroups.map((group) => (
				<section>
					{resolvedGroups.length > 1 && (
						<h3 class="mb-2 font-label text-[10px] uppercase tracking-[0.2em] text-on-surface-variant">{group.title}</h3>
					)}
					<ul class="space-y-1">
						{group.items.map((item) => (
							<li>
								<a
									href={item.href}
									class:list={[
										'flex items-center justify-between px-2 py-2 font-label text-xs uppercase tracking-[0.12em] transition-colors',
										item.active
											? 'border-l-2 border-primary bg-surface-container-high text-primary'
											: 'text-on-surface-variant hover:bg-surface-container-highest hover:text-on-surface',
									]}
								>
									<span>{item.label}</span>
									<span class="material-symbols-outlined text-sm" aria-hidden="true">subdirectory_arrow_right</span>
								</a>
							</li>
						))}
					</ul>
				</section>
			))
		}
	</nav>
</aside>
