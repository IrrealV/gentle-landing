---
const resources = [
	{ label: 'Documentation', href: '/docs' },
	{ label: 'How It Works', href: '/how-it-works' },
	{ label: 'Status', href: '/docs#runtime-sync' },
];

const community = [
	{ label: 'Features', href: '/features' },
	{ label: 'Configurator', href: '/configurator' },
	{ label: 'Terms', href: '/docs#interface-bridge' },
];
---

<footer data-home-section="footer" class="w-full border-t border-[#1a1f2e] bg-[#06080f] px-8 py-12">
	<div class="mx-auto flex w-full max-w-7xl flex-col gap-10">
		<div class="grid grid-cols-1 gap-10 md:grid-cols-3">
			<div class="space-y-4">
				<div class="flex items-center gap-2">
					<span class="flex h-6 w-6 items-center justify-center border border-[#1a1f2e] bg-surface-container-low text-[#7FB4CA]">
						<span class="material-symbols-outlined text-sm">terminal</span>
					</span>
					<span class="font-['Space_Grotesk'] text-xl font-bold uppercase tracking-tighter text-[#7FB4CA]">GENTLE-AI</span>
				</div>
				<p class="font-mono text-xs text-[#8892A0]">© 2024 Gentle-AI Ecosystem Configurator</p>
				<p class="font-mono text-[10px] uppercase tracking-widest text-secondary-fixed-dim">SYSTEM NODE: SAN FRANCISCO // CORE-01</p>
			</div>

			<div>
				<h4 class="mb-4 font-mono text-[10px] uppercase tracking-widest text-[#8892A0]">Resources</h4>
				<ul class="space-y-3">
					{
						resources.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-mono text-xs text-[#8892A0] underline decoration-dotted opacity-80 transition-opacity hover:text-[#7FB4CA] hover:opacity-100"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<h4 class="mb-4 font-mono text-[10px] uppercase tracking-widest text-[#8892A0]">Community</h4>
				<ul class="space-y-3">
					{
						community.map((link) => (
							<li>
								<a
									href={link.href}
									class="font-mono text-xs text-[#8892A0] underline decoration-dotted opacity-80 transition-opacity hover:text-[#7FB4CA] hover:opacity-100"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div class="flex flex-col items-center justify-between gap-4 border-t border-[#1a1f2e] pt-6 md:flex-row">
			<span class="font-mono text-[10px] uppercase tracking-widest text-[#8892A0] opacity-50">v4.8.12-PROD</span>
			<div class="flex items-center gap-4">
				<a href="/docs" class="flex h-10 w-10 items-center justify-center border border-outline-variant transition-colors hover:border-primary">
					<span class="material-symbols-outlined text-[#8892A0]">terminal</span>
				</a>
				<div class="flex h-10 w-10 items-center justify-center border border-outline-variant opacity-60 grayscale">
					<span class="material-symbols-outlined text-[#8892A0]">lips</span>
				</div>
			</div>
		</div>
	</div>
</footer>
