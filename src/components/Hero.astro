---
interface Props {
	ctaPrimaryHref: `/${string}` | `#${string}`;
	ctaSecondaryHref: `/${string}` | `#${string}`;
}

const { ctaPrimaryHref, ctaSecondaryHref } = Astro.props;
---

<section data-home-section="hero" class="mx-auto grid max-w-[1200px] grid-cols-1 items-center gap-12 px-6 pb-24 pt-12 lg:grid-cols-2">
	<div>
		<div class="mb-6 inline-flex items-center gap-2 border border-outline-variant bg-surface-container-low px-3 py-1">
			<span class="h-2 w-2 bg-tertiary"></span>
			<span class="mono text-[10px] uppercase tracking-widest text-on-surface-variant">V2.4.0 Codename: Ethereal</span>
		</div>
		<h1 class="mono mb-8 text-4xl font-extrabold leading-[1.1] tracking-tighter text-primary md:text-6xl">
			AI THAT UNDERSTANDS YOUR CODEBASE. NOT JUST YOUR PROMPT.
		</h1>
		<p class="mb-10 max-w-xl text-lg leading-relaxed text-on-surface-variant">
			Gentle-AI executes Spec-Driven Development to reduce guesswork and keep architecture coherent across the full delivery flow.
		</p>
		<div class="flex flex-wrap gap-4">
			<a
				href={ctaPrimaryHref}
				class="mono flex items-center gap-2 rounded border border-primary-container bg-primary-container px-8 py-4 text-sm font-bold uppercase text-on-primary transition-transform active:scale-95"
			>
				<span class="material-symbols-outlined" style="font-variation-settings: 'wght' 700;">code</span>
				View Protocols
			</a>
			<a
				href={ctaSecondaryHref}
				class="mono flex items-center gap-2 rounded border border-outline px-8 py-4 text-sm font-bold uppercase transition-colors hover:bg-surface-container-low"
			>
				<span class="material-symbols-outlined">description</span>
				Read Architecture
			</a>
		</div>
	</div>

	<div class="rounded-lg border border-outline-variant bg-surface-container-lowest p-1">
		<div class="overflow-hidden rounded-md border border-outline-variant bg-surface-container-low">
			<div class="flex items-center gap-2 border-b border-outline-variant bg-surface-container-high px-4 py-2">
				<div class="h-2.5 w-2.5 bg-window-control-red"></div>
				<div class="h-2.5 w-2.5 bg-window-control-amber"></div>
				<div class="h-2.5 w-2.5 bg-window-control-green"></div>
				<span class="mono ml-4 text-[10px] text-on-surface-variant opacity-50">zsh — gentle-ai --analyze</span>
			</div>
			<div class="mono overflow-x-auto p-6 text-sm leading-relaxed">
				<div class="mb-2 text-primary-container">$ gentle-ai init</div>
				<div class="mb-2 text-on-surface-variant">[SYSTEM] Scanning repository architecture...</div>
				<div class="mb-2 text-on-surface-variant">[SYSTEM] 124 files identified. Mapping dependencies.</div>
				<div class="mb-2 flex gap-2">
					<span class="text-tertiary">➜</span>
					<span class="text-on-surface">Generating .gentle/context.json</span>
				</div>
				<div class="mb-4 text-on-surface-variant">Done in 1.4s</div>
				<div class="mb-2 text-primary-container">$ gentle-ai apply full-landing-rebuild</div>
				<div class="mb-2 italic text-on-surface-variant">Loading spec, design, and task contracts...</div>
				<div class="mb-2 italic text-on-surface-variant">Implementing canonical section sequence...</div>
				<div class="flex gap-2">
					<span class="bg-primary-container px-1 text-on-primary">READY FOR VERIFY</span>
					<span class="animate-pulse text-on-surface">|</span>
				</div>
			</div>
		</div>
	</div>
</section>
